---
import { formatDateCN } from "@/utils/dates";
import type { SearchDoc } from "@/utils/siteSearchDocs";

type Props = {
  doc: SearchDoc;
};

const { doc } = Astro.props;
const publishDate = doc.publishDate ? new Date(doc.publishDate) : null;
const hasValidDate = Boolean(publishDate && !Number.isNaN(publishDate.getTime()));
const publishDateText = hasValidDate ? formatDateCN(publishDate as Date) : "";
---

<article class="site-doc-card">
  <div class="site-doc-card__meta">
    <span class="site-doc-card__kind">{doc.kind}</span>
    <span class="site-doc-card__category">{doc.category}</span>
    {hasValidDate && (
      <time class="site-doc-card__date" datetime={doc.publishDate}>{publishDateText}</time>
    )}
  </div>

  <a class="site-doc-card__title" href={doc.href}>
    {doc.title}
  </a>

  {(doc.excerpt || doc.description) && (
    <p class="site-doc-card__desc">{doc.excerpt || doc.description}</p>
  )}

  <div class="site-doc-card__footer">
    <div class="site-doc-card__tags">
      {(doc.tags || []).slice(0, 6).map((tag) => (
        <a class="site-doc-card__tag" href={`/tag/${encodeURIComponent(tag)}/`}>
          #{tag}
        </a>
      ))}
    </div>

    <a class="site-doc-card__more" href={doc.href}>
      查看内容 →
    </a>
  </div>
</article>

<style>
  .site-doc-card {
    background: #fff;
    border: 1px solid rgba(26, 29, 35, 0.09);
    border-radius: 14px;
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: box-shadow 0.18s, border-color 0.18s, transform 0.15s;
  }
  .site-doc-card:hover {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
    border-color: rgba(217, 45, 32, 0.22);
    transform: translateY(-1px);
  }
  .site-doc-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .site-doc-card__kind,
  .site-doc-card__category {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 999px;
    background: rgba(217, 45, 32, 0.08);
    color: #c02318;
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
  }
  .site-doc-card__kind {
    background: rgba(26, 86, 196, 0.08);
    color: #1a56c4;
  }
  .site-doc-card__date {
    font-size: 12px;
    color: rgba(26, 29, 35, 0.45);
  }
  .site-doc-card__title {
    font-size: 17px;
    font-weight: 800;
    color: #1a1d23;
    text-decoration: none;
    line-height: 1.45;
  }
  .site-doc-card__title:hover {
    color: #d92d20;
    text-decoration: none;
  }
  .site-doc-card__desc {
    font-size: 14px;
    color: rgba(26, 29, 35, 0.62);
    line-height: 1.7;
    margin: 0;
  }
  .site-doc-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 2px;
  }
  .site-doc-card__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .site-doc-card__tag {
    font-size: 12px;
    color: rgba(26, 29, 35, 0.56);
    text-decoration: none;
    padding: 2px 8px;
    border-radius: 999px;
    border: 1px solid rgba(26, 29, 35, 0.12);
    transition: border-color 0.15s, color 0.15s;
  }
  .site-doc-card__tag:hover {
    border-color: #d92d20;
    color: #d92d20;
    text-decoration: none;
  }
  .site-doc-card__more {
    font-size: 13px;
    font-weight: 700;
    color: #d92d20;
    text-decoration: none;
    white-space: nowrap;
  }
  .site-doc-card__more:hover {
    text-decoration: underline;
  }
</style>
