---
import {
  BLOG_HUB_SECTIONS_FULL,
  BLOG_HUB_SECTIONS_COMPACT,
  getCategoryContextSection,
} from "@/data/blogHubLinks";

type Props = {
  /** Narrow sidebar layout */
  compact?: boolean;
  /** Current blog category slug → prepend contextual links */
  category?: string;
  heading?: string;
};

const {
  compact = false,
  category,
  heading = "站内导航 · 延伸阅读",
} = Astro.props;

const extra = getCategoryContextSection(category);
const base = compact ? BLOG_HUB_SECTIONS_COMPACT : BLOG_HUB_SECTIONS_FULL;
const sections = extra ? [extra, ...base] : base;
---
<section class:list={["bih", compact && "bih--compact"]} aria-labelledby="bih-heading">
  <h2 id="bih-heading" class="bih__h">{heading}</h2>
  <div class="bih__grid">
    {sections.map((sec) => (
      <div class="bih__col">
        <h3 class="bih__t">{sec.title}</h3>
        <ul class="bih__ul">
          {sec.links.map((l) => (
            <li>
              <a href={l.href}>{l.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<style>
  .bih {
    margin-top: 8px;
    padding: 24px 22px 22px;
    background: linear-gradient(180deg, rgba(13, 17, 23, 0.03) 0%, transparent 100%);
    border: 1px solid rgba(13, 17, 23, 0.1);
    border-radius: 16px;
  }
  .bih--compact {
    padding: 16px 16px 14px;
    margin-top: 0;
    background: #fff;
  }
  .bih__h {
    font-size: 15px;
    font-weight: 800;
    color: #0d1117;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }
  .bih--compact .bih__h {
    font-size: 13px;
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(13, 17, 23, 0.08);
  }
  .bih__grid {
    display: grid;
    gap: 18px 20px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 520px) {
    .bih__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 900px) {
    .bih:not(.bih--compact) .bih__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1100px) {
    .bih:not(.bih--compact) .bih__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .bih--compact .bih__grid {
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .bih__t {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(13, 17, 23, 0.45);
    margin: 0 0 8px;
  }
  .bih__ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .bih__ul a {
    display: block;
    padding: 5px 0;
    font-size: 13px;
    color: #374151;
    text-decoration: none;
    line-height: 1.45;
    border-radius: 4px;
    transition: color 0.12s;
  }
  .bih__ul a:hover {
    color: #d92d20;
    text-decoration: underline;
  }
  .bih--compact .bih__ul a {
    font-size: 12.5px;
    padding: 4px 0;
  }
</style>
