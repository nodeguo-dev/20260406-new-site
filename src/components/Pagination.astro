---
import { getPageHref } from "@/utils/pagination";

type Props = {
  base: string;
  page: number;
  totalPages: number;
};

const { base, page, totalPages } = Astro.props;
const prevHref = page > 1 ? getPageHref(base, page - 1) : null;
const nextHref = page < totalPages ? getPageHref(base, page + 1) : null;

function getDisplayPages(current: number, total: number) {
  const pages = new Set<number>();
  pages.add(1);
  pages.add(total);
  for (let p = current - 2; p <= current + 2; p++) {
    if (p >= 1 && p <= total) pages.add(p);
  }
  const sorted = Array.from(pages).sort((a, b) => a - b);
  const out: Array<number | "…"> = [];
  let last = 0;
  for (const p of sorted) {
    if (last && p - last > 1) out.push("…");
    out.push(p);
    last = p;
  }
  return out;
}

const displayPages = getDisplayPages(page, totalPages);
---

<nav class="card" aria-label="分页">
  <div class="card-inner split">
    <div class="muted">第 {page} / {totalPages} 页</div>
    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; justify-content:flex-end;">
      {prevHref ? <a class="btn" href={prevHref}>上一页</a> : <span class="pill">已是第一页</span>}
      {nextHref ? <a class="btn" href={nextHref}>下一页</a> : <span class="pill">已是最后一页</span>}
    </div>
  </div>

  <div class="card-inner" style="padding-top:0">
    <div class="pagination-row">
      <div class="pagination-pages" aria-label="选择页码">
        {displayPages.map((p) =>
          p === "…" ? (
            <span class="pagination-ellipsis" aria-hidden="true">…</span>
          ) : (
            <a
              class={`pagination-page ${p === page ? "is-current" : ""}`}
              href={getPageHref(base, p)}
              aria-current={p === page ? "page" : undefined}
            >
              {p}
            </a>
          ),
        )}
      </div>

      <form class="pagination-jump" data-base={base} aria-label="跳转到指定页">
        <label class="muted" style="font-size:13px">跳转</label>
        <input
          class="input"
          name="page"
          type="number"
          min="1"
          max={totalPages}
          inputmode="numeric"
          placeholder={`${page}`}
          style="width:92px; padding:8px 10px"
        />
        <button class="btn" type="submit" style="padding:8px 12px">确定</button>
      </form>
    </div>
  </div>

  <script is:inline>
    document.querySelectorAll(".pagination-jump").forEach((form) => {
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const base = form.getAttribute("data-base") || "/";
        const input = form.querySelector('input[name="page"]');
        const n = Number(input?.value || "");
        if (!Number.isFinite(n) || n < 1) return;
        const normalizedBase = base.endsWith("/") ? base : `${base}/`;
        const href = n <= 1 ? normalizedBase : `${normalizedBase}page/${n}/`;
        window.location.href = href;
      });
    });
  </script>
</nav>

<style>
  .pagination-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .pagination-pages {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pagination-page {
    min-width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.86);
    color: var(--text);
    text-decoration: none;
    font-weight: 650;
    font-size: 14px;
  }

  .pagination-page:hover {
    border-color: rgba(217, 45, 32, 0.25);
  }

  .pagination-page.is-current {
    background: rgba(217, 45, 32, 0.1);
    border-color: rgba(217, 45, 32, 0.3);
    color: #7a1710;
  }

  .pagination-ellipsis {
    padding: 0 6px;
    color: rgba(31, 35, 40, 0.6);
  }

  .pagination-jump {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  @media (max-width: 560px) {
    .pagination-jump {
      width: 100%;
      justify-content: flex-start;
    }
  }
</style>
