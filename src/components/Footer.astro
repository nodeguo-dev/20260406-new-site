---
import { site } from "@/config/site";

/** 移民类：PR 路径、省提名、LMIA 等 */
const immigrationPrograms = [
  { href: "/projects/ee-category/", label: "EE定向移民" },
  { href: "/projects/provincial-nomination/", label: "各省省提名" },
  { href: "/projects/province/ontario/", label: "安省移民 OINP" },
  { href: "/projects/province/newfoundland/", label: "海洋四省 · NL" },
  { href: "/projects/province/nova-scotia/", label: "海洋四省 · NS" },
  { href: "/projects/province/new-brunswick/", label: "海洋四省 · NB" },
  { href: "/projects/province/prince-edward-island/", label: "海洋四省 · PEI" },
  { href: "/projects/province/manitoba/", label: "曼省留学移民" },
  { href: "/projects/lmia-overview/", label: "LMIA 雇主担保" },
  { href: "/projects/federal-programs/", label: "联邦移民项目" },
  { href: "/services/family-sponsorship-service/", label: "家庭团聚担保" },
];

/** 签证类：临时居民签证与续签 */
const visaServices = [
  { href: "/visa/study-permit/", label: "留学签证（学签）" },
  { href: "/visa/work-permit/", label: "工签（含雇主担保类）" },
  { href: "/visa/french-mobility-work-permit/", label: "法语流动工签" },
  { href: "/visa/c11-work-permit/", label: "C11 重大利益工签" },
  { href: "/visa/visitor/", label: "旅游签（访问签）" },
  { href: "/visa/family-visit/", label: "探亲签证" },
  { href: "/visa/super-visa/", label: "超级签证（父母）" },
  { href: "/visa/extend/", label: "续签 / 境内转换" },
];

const resources = [
  { href: "/blog/", label: "移民新闻动态" },
  { href: "/guides/toronto-life/", label: "多伦多生活指南" },
  { href: "/guides/toronto-life/partners/", label: "生活专题广告合作" },
  { href: "/faq/", label: "常见问题解答" },
  { href: "/noc/", label: "加拿大NOC职业库" },
  { href: "/immigration/guide/", label: "移民新手必读" },
  { href: "/category/policy/", label: "政策解读文章" },
  { href: "/school/", label: "免费申请学校" },
  { href: "/services/", label: "服务项目一览" },
];
---

<footer class="site-footer">

  <!-- ── Trust strip ─────────────────────────────────────────────── -->
  <div class="footer-trust-strip">
    <div class="container">
      <div class="fts-grid">
        <div class="fts-item">
          <span class="fts-icon">🇨🇦</span>
          <div>
            <div class="fts-title">RCIC 持牌顾问</div>
            <div class="fts-desc">CICC 正式注册，依法合规代理申请</div>
          </div>
        </div>
        <div class="fts-item">
          <span class="fts-icon">🏢</span>
          <div>
            <div class="fts-title">多伦多本地注册</div>
            <div class="fts-desc">北约克中心设有办公室，本地服务有保障</div>
          </div>
        </div>
        <div class="fts-item">
          <span class="fts-icon">✅</span>
          <div>
            <div class="fts-title">2500+ 成功案例</div>
            <div class="fts-desc">客户满意度 98%，以结果取信于人</div>
          </div>
        </div>
        <div class="fts-item">
          <span class="fts-icon">🕐</span>
          <div>
            <div class="fts-title">全周在线服务</div>
            <div class="fts-desc">{site.contact.hours}</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Main footer ────────────────────────────────────────────── -->
  <div class="container footer-main">
    <div class="footer-grid">

      <!-- Brand col -->
      <div class="footer-brand-col">
        <a href="/" class="footer-brand">
          <img src="/assets/logo.webp" alt="Logo" width="40" height="40" style="border-radius:10px"/>
          <span class="footer-brand-name">{site.name}</span>
        </a>
        <p class="footer-tagline">
          专业加拿大移民与签证咨询，陪伴华人家庭从申请到登陆，一路稳步前行。
        </p>
        <div class="footer-contact-list">
          <a href={`tel:${site.contact.phoneCA.replace(/[^+0-9]/g,'')}`} class="footer-contact-item" aria-label={`拨打加拿大直线 ${site.contact.phoneCA}`}>
            <span class="fci-icon">📞</span>
            <div>
              <div class="fci-label">加拿大直线</div>
              <div class="fci-value">{site.contact.phoneCA}</div>
            </div>
          </a>
          <a href={`tel:${site.contact.phoneCNPlain}`} class="footer-contact-item" aria-label={`拨打国内热线 ${site.contact.phoneCN}`}>
            <span class="fci-icon">🇨🇳</span>
            <div>
              <div class="fci-label">国内热线</div>
              <div class="fci-value">{site.contact.phoneCN}</div>
            </div>
          </a>
          <div class="footer-contact-item">
            <span class="fci-icon">💬</span>
            <div>
              <div class="fci-label">微信号</div>
              <div class="fci-value">{site.contact.wechat}</div>
            </div>
          </div>
          <a href={`mailto:${site.contact.email}`} class="footer-contact-item" aria-label={`发邮件至 ${site.contact.email}`}>
            <span class="fci-icon">✉️</span>
            <div>
              <div class="fci-label">邮件咨询</div>
              <div class="fci-value">{site.contact.email}</div>
            </div>
          </a>
        </div>
        <div class="footer-title footer-title--after-contact">办公地点</div>
        <ul class="footer-links footer-links--compact">
          {site.contact.locations.map((l) => (
            <li>
              <span class="fl-loc-label">{l.label}：</span>
              {l.value}
            </li>
          ))}
        </ul>
      </div>

      <!-- Immigration + Visa cols (split) -->
      <div class="footer-services-split">
        <div class="footer-subcol">
          <div class="footer-title">移民项目</div>
          <ul class="footer-links">
            {immigrationPrograms.map((s) => (
              <li><a href={s.href}>{s.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer-subcol">
          <div class="footer-title">签证服务</div>
          <ul class="footer-links">
            {visaServices.map((s) => (
              <li><a href={s.href}>{s.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Resources col -->
      <div class="footer-resources-col">
        <div class="footer-title">资讯与资源</div>
        <ul class="footer-links">
          {resources.map((r) => (
            <li><a href={r.href}>{r.label}</a></li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- ── Bottom bar ─────────────────────────────────────────────── -->
  <div class="container footer-bottom">
    <div class="footer-bottom-left">
      <span>© {new Date().getFullYear()} {site.name}. 保留所有权利。</span>
      <span class="footer-sep">·</span>
      <a href="/about/">关于我们</a>
      <span class="footer-sep">·</span>
      <a href="/contact/">联系我们</a>
      <span class="footer-sep">·</span>
      <a href="https://plansale.ca" target="_blank" rel="noopener noreferrer">Optimized by Plansale</a>
    </div>
    <div class="footer-disclaimer">
      {site.disclaimer}
    </div>
  </div>
</footer>

<style>
/* ── Trust Strip ─────────────────────────────────────────────────── */
.footer-trust-strip {
  background: rgba(255,255,255,0.04);
  border-bottom: 1px solid rgba(255,255,255,0.07);
  padding: 28px 0;
}
.fts-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
@media (min-width: 960px) { .fts-grid { grid-template-columns: repeat(4,1fr); } }
.fts-item {
  display: flex;
  align-items: center;
  gap: 14px;
}
.fts-icon { font-size: 23px; flex-shrink: 0; }
.fts-title { font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.92); margin-bottom: 4px; }
.fts-desc  { font-size: 12px; color: rgba(255,255,255,0.48); line-height: 1.55; }

/* ── Main Footer ─────────────────────────────────────────────────── */
.footer-main { padding: 72px 0 52px; }
.footer-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px 28px;
  align-items: start;
}
@media (min-width: 1024px) {
  .footer-grid {
    grid-template-columns: minmax(260px, 1.08fr) minmax(0, 0.96fr) minmax(0, 0.96fr);
    grid-template-areas: "brand services resources";
    gap: 56px 42px;
  }
}

/* Brand Col */
.footer-brand-col { min-width: 0; }
.footer-resources-col { min-width: 0; }
.footer-brand-col {
  max-width: 340px;
}
.footer-brand-col { grid-area: brand; }
.footer-services-split { grid-area: services; }
.footer-resources-col { grid-area: resources; }
.footer-brand {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  margin-bottom: 18px;
}
.footer-brand:hover { text-decoration: none; }
.footer-brand-name {
  font-size: 17px;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.02em;
}
.footer-tagline {
  font-size: 13.5px;
  color: rgba(255,255,255,0.5);
  line-height: 1.9;
  margin: 0 0 26px;
  max-width: 330px;
}
.footer-contact-list { display: flex; flex-direction: column; gap: 14px; }
.footer-contact-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  text-decoration: none;
  transition: opacity 0.15s;
}
.footer-contact-item:hover { opacity: 0.85; text-decoration: none; }
.fci-icon { font-size: 16px; flex-shrink: 0; width: 24px; text-align: center; padding-top: 2px; }
.fci-label { font-size: 11px; color: rgba(255,255,255,0.42); line-height: 1.25; margin-bottom: 2px; }
.fci-value { font-size: 13.5px; color: rgba(255,255,255,0.84); font-weight: 650; line-height: 1.5; }

/* Footer links */
.footer-title {
  color: #fff;
  font-weight: 700;
  font-size: 15px;
  margin-bottom: 16px;
  letter-spacing: -0.01em;
}
.footer-title--after-contact { margin-top: 30px; margin-bottom: 14px; }
.footer-links--compact {
  gap: 8px;
}
.footer-links--compact li {
  font-size: 13.5px;
  color: rgba(255,255,255,0.52);
  line-height: 1.75;
  padding: 3px 0;
}
.fl-loc-label { color: rgba(255,255,255,0.38); font-size: 12px; }
.footer-links {
  list-style: none;
  padding: 0; margin: 0;
  display: flex; flex-direction: column; gap: 11px;
}
.footer-links li { }
.footer-links a {
  font-size: 13.5px;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  transition: color 0.15s;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 5px 0;
  line-height: 1.55;
}
.footer-links a:hover { color: #fff; text-decoration: none; }
.footer-links a::before {
  content: '→';
  opacity: 0;
  transform: translateX(-6px);
  transition: opacity 0.15s, transform 0.15s;
  font-size: 11px;
}
.footer-links a:hover::before { opacity: 0.6; transform: translateX(0); }

.footer-services-split {
  display: grid;
  grid-template-columns: 1fr;
  gap: 28px 28px;
  align-content: start;
  min-width: 0;
}
@media (min-width: 900px) {
  .footer-services-split {
    grid-template-columns: 1fr 1fr;
  }
}
.footer-subcol { min-width: 0; }

/* Bottom Bar — extra bottom padding so fixed 咨询按钮少压住版权链接 */
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 26px 0 max(34px, calc(24px + env(safe-area-inset-bottom, 0px)));
  display: flex;
  flex-direction: column;
  gap: 14px;
}
@media (max-width: 1023px) {
  .footer-bottom {
    padding-bottom: max(86px, calc(60px + env(safe-area-inset-bottom, 0px)));
  }
}
@media (min-width: 960px) { .footer-bottom { flex-direction: row; align-items: center; justify-content: space-between; } }
.footer-bottom-left {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  font-size: 12.5px;
  color: rgba(255,255,255,0.42);
}
.footer-bottom-left a { color: rgba(255,255,255,0.5); }
.footer-bottom-left a:hover { color: #fff; text-decoration: none; }
.footer-sep { opacity: 0.3; }
.footer-disclaimer {
  font-size: 11.5px;
  color: rgba(255,255,255,0.34);
  max-width: 560px;
  line-height: 1.65;
}

@media (max-width: 1023px) {
  .footer-main { padding: 56px 0 36px; }
  .footer-grid {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }
  .footer-brand-col,
  .footer-services-split,
  .footer-resources-col {
    max-width: none;
    width: 100%;
  }
  .footer-brand {
    margin-bottom: 14px;
  }
  .footer-tagline {
    max-width: none;
    margin-bottom: 22px;
  }
  .footer-contact-list {
    gap: 12px;
  }
  .footer-title {
    margin-bottom: 12px;
  }
  .footer-links,
  .footer-links--compact {
    gap: 8px;
  }
  .footer-services-split {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .footer-subcol {
    width: 100%;
  }
}

@media (max-width: 640px) {
  .site-footer .container {
    padding-left: 32px;
    padding-right: 32px;
  }
  .footer-main { padding: 48px 0 32px; }
  .footer-trust-strip { padding: 22px 0; }
  .fts-grid {
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .fts-item {
    align-items: flex-start;
  }
  .fts-title {
    font-size: 13px;
  }
  .footer-contact-item {
    gap: 10px;
    padding: 8px 0;
    align-items: flex-start;
  }
  .fci-value {
    word-break: break-word;
  }
  .footer-title--after-contact {
    margin-top: 22px;
    margin-bottom: 10px;
  }
  .footer-contact-list {
    gap: 10px;
  }
  .footer-links {
    gap: 6px;
  }
  .footer-links a {
    padding: 4px 0;
    display: flex;
    align-items: flex-start;
  }
  .footer-links a::before {
    margin-top: 1px;
  }
  .footer-links a,
  .footer-links--compact li {
    font-size: 13px;
    line-height: 1.6;
  }
  .footer-brand-col {
    padding-left: 2px;
  }
  .footer-links--compact li {
    padding: 2px 0;
  }
  .footer-bottom-left {
    gap: 8px;
    line-height: 1.55;
  }
  .footer-disclaimer {
    font-size: 11px;
  }
}
</style>
