---
import { formatDateCN } from "@/utils/dates";
import type { CollectionEntry } from "astro:content";
import { categoryMeta } from "@/data/categoryMeta";

type Props = {
  post: CollectionEntry<"blog">;
  variant?: "list" | "card";
};

const { post, variant = "list" } = Astro.props;
const publish = new Date(post.data.publishDate);
const categoryLabel = categoryMeta[post.data.category]?.title ?? post.data.category;
const categorySlug = post.data.category;
---

{variant === "card" ? (
  <article class="post-card">
    <div class="post-card-cat-bar">
      <a class="post-cat-badge" href={`/category/${categorySlug}/`}>{categoryLabel}</a>
      <time class="post-date" datetime={post.data.publishDate}>{formatDateCN(publish)}</time>
    </div>
    <a class="post-card-title" href={`/blog/${post.slug}/`}>{post.data.title}</a>
    <p class="post-card-excerpt">{post.data.excerpt}</p>
    <div class="post-card-footer">
      {post.data.tags?.slice(0, 5).map((t) => (
        <a class="post-tag" href={`/tag/${encodeURIComponent(t)}/`}>#{t}</a>
      ))}
      <a class="post-read-more" href={`/blog/${post.slug}/`}>阅读全文 →</a>
    </div>
  </article>
) : (
  <article class="post-list-item">
    <div class="post-list-meta">
      <a class="post-cat-badge" href={`/category/${categorySlug}/`}>{categoryLabel}</a>
      <time class="post-date" datetime={post.data.publishDate}>{formatDateCN(publish)}</time>
    </div>
    <a class="post-list-title" href={`/blog/${post.slug}/`}>{post.data.title}</a>
    <p class="post-list-excerpt">{post.data.excerpt}</p>
    <div class="post-list-footer">
      <div class="post-tags">
        {post.data.tags?.slice(0, 6).map((t) => (
          <a class="post-tag" href={`/tag/${encodeURIComponent(t)}/`}>#{t}</a>
        ))}
      </div>
      <a class="post-read-more" href={`/blog/${post.slug}/`}>阅读全文 →</a>
    </div>
  </article>
)}

<style>
/* ── CARD VARIANT ────────────────────────────────────────────────── */
.post-card {
  background: #fff;
  border: 1px solid rgba(26,29,35,0.09);
  border-radius: 14px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  transition: box-shadow 0.2s, border-color 0.2s, transform 0.15s;
}
.post-card:hover {
  box-shadow: 0 6px 24px rgba(0,0,0,0.10);
  border-color: rgba(217,45,32,0.2);
  transform: translateY(-2px);
}
.post-card-cat-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.post-card-title {
  font-size: 16px;
  font-weight: 700;
  color: #1a1d23;
  text-decoration: none;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.post-card-title:hover { color: #d92d20; text-decoration: none; }
.post-card-excerpt {
  font-size: 13px;
  color: rgba(26,29,35,0.58);
  line-height: 1.65;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}
.post-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 4px;
}

/* ── LIST VARIANT ────────────────────────────────────────────────── */
.post-list-item {
  background: #fff;
  border: 1px solid rgba(26,29,35,0.09);
  border-radius: 14px;
  padding: 20px 22px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: box-shadow 0.18s, border-color 0.18s, transform 0.15s;
}
.post-list-item:hover {
  box-shadow: 0 4px 20px rgba(0,0,0,0.09);
  border-color: rgba(217,45,32,0.22);
  transform: translateY(-1px);
}
.post-list-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.post-list-title {
  font-size: 17px;
  font-weight: 700;
  color: #1a1d23;
  text-decoration: none;
  line-height: 1.45;
}
.post-list-title:hover { color: #d92d20; text-decoration: none; }
.post-list-excerpt {
  font-size: 14px;
  color: rgba(26,29,35,0.6);
  line-height: 1.7;
  margin: 0;
}
.post-list-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 4px;
}
.post-tags { display: flex; gap: 6px; flex-wrap: wrap; }

/* ── SHARED ──────────────────────────────────────────────────────── */
.post-cat-badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  border-radius: 999px;
  background: rgba(217,45,32,0.08);
  color: #c02318;
  font-size: 12px;
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
}
.post-cat-badge:hover { background: rgba(217,45,32,0.14); text-decoration: none; }
.post-date {
  font-size: 12px;
  color: rgba(26,29,35,0.45);
}
.post-tag {
  font-size: 12px;
  color: rgba(26,29,35,0.55);
  text-decoration: none;
  padding: 2px 8px;
  border-radius: 999px;
  border: 1px solid rgba(26,29,35,0.12);
  transition: border-color 0.15s, color 0.15s;
}
.post-tag:hover { border-color: #d92d20; color: #d92d20; text-decoration: none; }
.post-read-more {
  font-size: 13px;
  font-weight: 600;
  color: #d92d20;
  text-decoration: none;
  white-space: nowrap;
}
.post-read-more:hover { text-decoration: underline; }
</style>
