---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogInternalHub from "@/components/BlogInternalHub.astro";
import Pagination from "@/components/Pagination.astro";
import ContactCard from "@/components/ContactCard.astro";
import RelatedToolsCard from "@/components/RelatedToolsCard.astro";
import { withSiteTitle } from "@/utils/seo";
import { buildSiteSearchDocs, collectSiteTags, sortDocsByDateDesc } from "@/utils/siteSearchDocs";
import { getPageSlice } from "@/utils/pagination";
import SiteDocCard from "@/components/SiteDocCard.astro";
import { encodeTagSlug, resolveTagFromSlug } from "@/utils/tagRoutes";

const PAGE_SIZE = 12;

export async function getStaticPaths() {
  const { getPageSlice } = await import("@/utils/pagination");
  const docs = await buildSiteSearchDocs();
  const tags = collectSiteTags(docs);
  const paths = [];
  for (const tag of tags) {
    const tagDocs = docs.filter((doc) => doc.tags?.includes(tag));
    const { totalPages } = getPageSlice(tagDocs, 1, 12);
    for (let page = 2; page <= totalPages; page += 1) {
      paths.push({ params: { slug: encodeTagSlug(tag), page: String(page) } });
    }
  }
  return paths;
}

const allDocs = await buildSiteSearchDocs();
const { slug, page } = Astro.params;
const tag = resolveTagFromSlug(slug, collectSiteTags(allDocs));
const pageNum = Number(page);
const tagDocs = sortDocsByDateDesc(allDocs.filter((doc) => doc.tags?.includes(tag)));
const { items, totalPages } = getPageSlice(tagDocs, pageNum, PAGE_SIZE);

const allTags = collectSiteTags(allDocs);
const tagCounts = allTags
  .map((t) => ({
    tag: t,
    count: allDocs.filter((doc) => doc.tags?.includes(t)).length,
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 30);

const kindMeta: Record<string, { label: string; href: string }> = {
  博客: { label: "博客", href: "/blog/" },
  服务: { label: "服务页", href: "/services/" },
  项目: { label: "项目页", href: "/projects/" },
  百科: { label: "百科", href: "/baike/" },
  院校: { label: "院校", href: "/school/" },
  职业库: { label: "NOC 职业库", href: "/noc/" },
};
const relatedKinds = [...new Set(tagDocs.map((doc) => doc.kind).filter(Boolean))];
const allKinds = [...new Set(allDocs.map((doc) => doc.kind).filter(Boolean))];
---

<BaseLayout
  title={withSiteTitle(`#${tag} | 站内内容 - 第 ${pageNum} 页`)}
  description={`浏览所有带有标签「${tag}」的站内内容，第 ${pageNum} 页，共 ${totalPages} 页。`}
  canonical={`https://cachinavisa.com/tag/${encodeTagSlug(tag)}/page/${pageNum}/`}
>
  <div class="tag-layout">
    <main>
      <div class="tag-hero">
        <div class="tag-hero-kicker">标签</div>
        <h1 class="tag-hero-title">
          <span class="tag-hash">#</span>{tag} <span class="tag-page">第 {pageNum} 页</span>
        </h1>
        <div class="tag-hero-meta">
          <span class="thm-count">{tagDocs.length} 条内容</span>
          {relatedKinds.length > 0 && <span class="thm-sep">·</span>}
          {relatedKinds.map((kind) => (
            <a class="thm-cat" href={kindMeta[kind]?.href ?? "/search/"}>
              {kindMeta[kind]?.label ?? kind}
            </a>
          ))}
        </div>
      </div>

      {items.length > 0 ? (
        <div class="posts-list">
          {items.map((doc) => <SiteDocCard doc={doc} />)}
        </div>
      ) : (
        <div class="empty-state">
          <div class="es-icon">🏷️</div>
          <div class="es-title">暂无文章</div>
          <p class="es-desc">该标签下暂时没有已发布的内容，请稍后再来。</p>
          <a href="/search/" class="btn-soft">查看站内搜索</a>
        </div>
      )}

      <div class="pagination-wrap">
        <Pagination base={`/tag/${slug}/`} page={pageNum} totalPages={totalPages} />
      </div>

      <section class="tag-hub-wrap" aria-labelledby="tag-hub-main">
        <h2 id="tag-hub-main" class="visually-hidden">站内导航与延伸阅读</h2>
        <BlogInternalHub />
      </section>
    </main>

    <aside class="tag-sidebar">
      <ContactCard />
      <RelatedToolsCard
        title="相关打分工具"
        subtitle="标签页里如果看到 CRS / EOI / 打分，先把工具打开。"
        items={[
          { href: "/tools/crs-calculator/", label: "联邦 CRS 计算器", desc: "EE / CEC / FSW 的基础自测工具。" },
          { href: "/tools/oinp-calculator/", label: "安省 OINP · EOI", desc: "安省雇主类 / 留学类常见入口。" },
          { href: "/tools/bc-pnp-calculator/", label: "BC SIRS 计算器", desc: "BC 技术移民常用分值预估。" },
          { href: "/tools/aaip-calculator/", label: "AAIP Worker EOI", desc: "阿省相关路径的分值自测。" },
        ]}
        footerHref="/tools/"
        footerLabel="进入全部打分工具"
      />
      <div class="sidebar-card">
        <div class="sidebar-card-title">热门标签</div>
        <div class="tag-cloud">
          {tagCounts.map(({ tag: t, count }) => (
            <a
              class={`tag-cloud-item${t === tag ? ' active' : ''}`}
              href={`/tag/${encodeTagSlug(t)}/`}
            >
              <span>#{t}</span>
              <span class="tc-count">{count}</span>
            </a>
          ))}
        </div>
      </div>
      <div class="sidebar-card">
        <div class="sidebar-card-title">相关内容类型</div>
        <div class="sidebar-cats">
          {relatedKinds.map((kind) => (
            <a class="scat-item" href={kindMeta[kind]?.href ?? "/search/"}>
              {kindMeta[kind]?.label ?? kind}
            </a>
          ))}
          {relatedKinds.length === 0 && (
            <div style="padding:12px 20px; font-size:13px; color:rgba(13,17,23,0.4)">暂无相关内容类型</div>
          )}
        </div>
      </div>
      <div class="sidebar-card">
        <div class="sidebar-card-title">全部内容频道</div>
        <div class="sidebar-cats">
          {allKinds.map((kind) => (
            <a class="scat-item" href={kindMeta[kind]?.href ?? "/search/"}>
              {kindMeta[kind]?.label ?? kind}
            </a>
          ))}
        </div>
      </div>
      <div class="sidebar-card">
        <div class="sidebar-card-title">快速入口</div>
        <div class="quick-links">
          <a class="ql" href="/blog/">移民新闻</a>
          <a class="ql" href="/immigration/guide/">新手必读</a>
          <a class="ql" href="/tools/">打分工具</a>
          <a class="ql" href="/search/">站内搜索</a>
          <a class="ql" href="/contact/">咨询</a>
        </div>
      </div>
      <div class="sidebar-card sidebar-card--hub">
        <BlogInternalHub compact heading="热门内链" />
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  .tag-layout {
    display: grid; grid-template-columns: 1fr;
    gap: 24px; align-items: start;
  }
  @media (min-width: 960px) { .tag-layout { grid-template-columns: 1fr 280px; } }

  .tag-hero {
    background: linear-gradient(135deg, #0a1628 0%, #0f2040 60%, #1a1040 100%);
    border-radius: 18px; padding: 36px 32px; margin-bottom: 20px;
    position: relative; overflow: hidden;
  }
  .tag-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 50% 70% at 85% 25%, rgba(124,58,237,0.2), transparent 65%);
    pointer-events: none;
  }
  .tag-hero-kicker {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: rgba(167,139,250,0.8); margin-bottom: 10px;
    position: relative; z-index: 1;
  }
  .tag-hero-title {
    font-size: clamp(24px, 4vw, 36px); font-weight: 900; color: #fff;
    margin: 0 0 14px; letter-spacing: -0.025em; position: relative; z-index: 1;
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  }
  .tag-hash { color: rgba(167,139,250,0.8); }
  .tag-page { font-size: 14px; font-weight: 650; color: rgba(255,255,255,0.58); }
  .tag-hero-meta {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    position: relative; z-index: 1;
  }
  .thm-count {
    display: inline-block; padding: 4px 12px; border-radius: 999px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.7); font-size: 12px; font-weight: 600;
  }
  .thm-sep { color: rgba(255,255,255,0.3); }
  .thm-cat {
    font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.6);
    text-decoration: none; padding: 3px 10px; border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.15);
    transition: color 0.15s, border-color 0.15s;
  }
  .thm-cat:hover { color: #fff; border-color: rgba(255,255,255,0.3); text-decoration: none; }

  .posts-list { display: flex; flex-direction: column; gap: 10px; }
  .pagination-wrap { margin-top: 24px; }

  .empty-state {
    text-align: center; padding: 60px 20px;
    background: #fff; border: 1px solid rgba(13,17,23,0.08);
    border-radius: 16px;
  }
  .es-icon  { font-size: 48px; margin-bottom: 16px; }
  .es-title { font-size: 18px; font-weight: 700; color: #0d1117; margin-bottom: 8px; }
  .es-desc  { font-size: 14px; color: rgba(13,17,23,0.55); line-height: 1.7; margin: 0 0 20px; }

  .tag-sidebar { display: flex; flex-direction: column; gap: 16px; position: sticky; top: 88px; }
  .sidebar-card {
    background: #fff; border: 1px solid rgba(13,17,23,0.09);
    border-radius: 16px; overflow: hidden;
  }
  .sidebar-card-title {
    font-size: 14px; font-weight: 700; color: #0d1117;
    padding: 16px 20px 12px; border-bottom: 1px solid rgba(13,17,23,0.07);
  }
  .tag-cloud { padding: 12px 16px; display: flex; flex-wrap: wrap; gap: 6px; }
  .tag-cloud-item {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 10px; border-radius: 8px; font-size: 12px;
    color: rgba(13,17,23,0.65); border: 1px solid rgba(13,17,23,0.1);
    text-decoration: none; transition: all 0.12s;
  }
  .tag-cloud-item:hover { border-color: rgba(217,45,32,0.3); color: #d92d20; text-decoration: none; }
  .tag-cloud-item.active { background: rgba(217,45,32,0.08); border-color: rgba(217,45,32,0.3); color: #d92d20; font-weight: 700; }
  .tc-count { font-size: 11px; color: rgba(13,17,23,0.35); }

  .sidebar-cats { padding: 8px 0; }
  .scat-item {
    display: block; padding: 9px 20px;
    font-size: 13.5px; color: rgba(13,17,23,0.7);
    text-decoration: none; transition: background 0.12s, color 0.12s;
  }
  .scat-item:hover { background: rgba(217,45,32,0.04); color: #d92d20; text-decoration: none; }

  .tag-hub-wrap { margin-top: 8px; }
  .visually-hidden {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  .quick-links { display: flex; flex-direction: column; gap: 2px; padding: 4px 0; }
  .ql {
    padding: 8px 16px; font-size: 13.5px; color: rgba(13,17,23,0.7);
    text-decoration: none;
  }
  .ql:hover { background: rgba(217,45,32,0.04); color: #d92d20; text-decoration: none; }
</style>
