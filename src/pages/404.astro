---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/config/site";
import { withSiteTitle } from "@/utils/seo";
import { getAllPublishedPosts } from "@/utils/content";

/** 静态托管会把任意未匹配 URL 落到本页；规范 URL 固定为 /404/，勿用当前浏览器路径作 canonical */
const canonical404 = new URL("/404/", site.url).href;
Astro.response.status = 404;

const posts = await getAllPublishedPosts();
const recent = posts.slice(0, 4);

const quickLinks = [
  { href: "/projects/", icon: "🍁", label: "移民项目", desc: "联邦、省提名全部项目" },
  { href: "/visa/", icon: "📋", label: "签证服务", desc: "访客签、学签、工签等" },
  { href: "/visa/french-mobility-work-permit/", icon: "🇫🇷", label: "法语流动工签", desc: "魁省外 · C16 · 法语听说符合要求时可免 LMIA" },
  { href: "/visa/c11-work-permit/", icon: "🚀", label: "C11 重大利益工签", desc: "创业与特殊人才路径" },
  { href: "/category/inland-affairs/", icon: "🏠", label: "境内事务", desc: "续签、身份衔接、PR 卡" },
  { href: "/immigration/guide/", icon: "📘", label: "新手必读", desc: "路径与时间线入门" },
  { href: "/tools/", icon: "📊", label: "打分工具", desc: "EE / PNP 分数估算" },
  { href: "/blog/", icon: "📰", label: "移民新闻", desc: "最新政策解读与指南" },
  { href: "/faq/", icon: "❓", label: "常见问题", desc: "高频咨询问题解答" },
  { href: "/contact/", icon: "💬", label: "联系我们", desc: "免费路径评估咨询" },
];
---

<BaseLayout
  title={withSiteTitle("404 · 页面未找到")}
  description="您访问的页面不存在或已被移动，请返回首页或使用站内搜索找到您需要的内容。"
  canonical={canonical404}
  fullWidth={true}
  noindex={true}
>
  <section class="notfound-hero">
    <div class="nh-bg"></div>
    <div class="container nh-inner">
      <div class="nh-code">404</div>
      <h1 class="nh-title">页面未找到</h1>
      <p class="nh-desc">您访问的页面不存在或已被移动，请尝试以下入口找到您需要的内容。</p>
      <div class="nh-actions">
        <a class="nh-btn-primary" href="/">返回首页</a>
        <a class="nh-btn-ghost" href="/search/">站内搜索</a>
      </div>
    </div>
  </section>

  <div class="container notfound-body">
    <!-- Quick links -->
    <section class="nf-section">
      <h2 class="nf-title">常用页面入口</h2>
      <div class="nf-link-grid">
        {quickLinks.map((l) => (
          <a class="nf-link-card" href={l.href}>
            <span class="nf-link-icon">{l.icon}</span>
            <div>
              <div class="nf-link-label">{l.label}</div>
              <div class="nf-link-desc">{l.desc}</div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Recent posts -->
    {recent.length > 0 && (
      <section class="nf-section">
        <h2 class="nf-title">最新文章</h2>
        <div class="nf-posts">
          {recent.map((p) => (
            <a class="nf-post" href={`/blog/${p.slug}/`}>
              <div class="nf-post-title">{p.data.title}</div>
              <div class="nf-post-excerpt">{p.data.excerpt}</div>
            </a>
          ))}
        </div>
        <div style="margin-top:16px; text-align:center">
          <a class="nf-btn-ghost-dark" href="/blog/">查看全部文章 →</a>
        </div>
      </section>
    )}

    <!-- Contact strip -->
    <section class="nf-contact-strip">
      <div class="nf-cs-text">
        <div class="nf-cs-title">需要帮助？直接联系我们</div>
        <div class="nf-cs-sub">加拿大：{site.contact.phoneCA}&nbsp;&nbsp;|&nbsp;&nbsp;国内：{site.contact.phoneCN}&nbsp;&nbsp;|&nbsp;&nbsp;微信：{site.contact.wechat}</div>
      </div>
      <a class="nh-btn-primary" href="/contact/">免费咨询</a>
    </section>
  </div>

</BaseLayout>

<style>
/* ── 404 HERO ─────────────────────────────────────────────────── */
.notfound-hero {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #0a1628 0%, #0f1f38 50%, #0a1628 100%);
  padding: 96px 0 80px;
  text-align: center;
}
.nh-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 60% at 50% 30%, rgba(217,45,32,0.18) 0%, transparent 70%);
  pointer-events: none;
}
.nh-inner { position: relative; z-index: 1; }
.nh-code {
  font-size: clamp(80px, 18vw, 160px);
  font-weight: 900;
  line-height: 1;
  color: transparent;
  -webkit-text-stroke: 2px rgba(217,45,32,0.5);
  letter-spacing: -0.04em;
  margin-bottom: 8px;
  user-select: none;
}
.nh-title {
  font-size: clamp(22px, 4vw, 32px);
  font-weight: 800;
  color: #fff;
  margin: 0 0 12px;
}
.nh-desc {
  font-size: 16px;
  color: rgba(255,255,255,0.6);
  margin: 0 0 32px;
  max-width: 480px;
  margin-left: auto;
  margin-right: auto;
}
.nh-actions {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
}
.nh-btn-primary {
  display: inline-flex;
  align-items: center;
  padding: 12px 24px;
  border-radius: 12px;
  background: #d92d20;
  color: #fff;
  font-weight: 700;
  font-size: 15px;
  text-decoration: none;
  transition: background 0.2s, transform 0.15s;
}
.nh-btn-primary:hover { background: #b52418; transform: translateY(-1px); text-decoration: none; }
.nh-btn-ghost {
  display: inline-flex;
  align-items: center;
  padding: 12px 24px;
  border-radius: 12px;
  background: rgba(255,255,255,0.09);
  color: rgba(255,255,255,0.85);
  font-weight: 600;
  font-size: 15px;
  text-decoration: none;
  border: 1px solid rgba(255,255,255,0.18);
  transition: background 0.2s;
}
.nh-btn-ghost:hover { background: rgba(255,255,255,0.14); text-decoration: none; }

/* ── BODY ─────────────────────────────────────────────────────── */
.notfound-body { padding-top: 40px; padding-bottom: 48px; }
.nf-section { margin-bottom: 44px; }
.nf-title {
  font-size: 20px;
  font-weight: 750;
  color: #1a1d23;
  margin: 0 0 18px;
}

/* ── QUICK LINKS ─────────────────────────────────────────────── */
.nf-link-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}
@media (min-width: 600px) { .nf-link-grid { grid-template-columns: repeat(3, 1fr); } }
@media (min-width: 960px) { .nf-link-grid { grid-template-columns: repeat(5, 1fr); } }
.nf-link-card {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px;
  border-radius: 14px;
  border: 1px solid rgba(26,29,35,0.09);
  background: #fff;
  text-decoration: none;
  color: #1a1d23;
  transition: border-color 0.18s, box-shadow 0.18s, transform 0.15s;
}
.nf-link-card:hover {
  border-color: rgba(217,45,32,0.28);
  box-shadow: 0 4px 16px rgba(217,45,32,0.08);
  transform: translateY(-2px);
  text-decoration: none;
}
.nf-link-icon { font-size: 22px; flex-shrink: 0; margin-top: 1px; }
.nf-link-label { font-weight: 700; font-size: 14px; }
.nf-link-desc { font-size: 12px; color: rgba(26,29,35,0.55); margin-top: 2px; }

/* ── RECENT POSTS ────────────────────────────────────────────── */
.nf-posts { display: grid; gap: 10px; }
@media (min-width: 640px) { .nf-posts { grid-template-columns: repeat(2, 1fr); } }
.nf-post {
  padding: 18px;
  border-radius: 14px;
  border: 1px solid rgba(26,29,35,0.09);
  background: #fff;
  text-decoration: none;
  transition: border-color 0.18s, box-shadow 0.18s, transform 0.15s;
}
.nf-post:hover {
  border-color: rgba(217,45,32,0.25);
  box-shadow: 0 4px 16px rgba(217,45,32,0.07);
  transform: translateY(-1px);
  text-decoration: none;
}
.nf-post-title {
  font-size: 15px;
  font-weight: 700;
  color: #1a1d23;
  line-height: 1.4;
  margin-bottom: 6px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.nf-post:hover .nf-post-title { color: #d92d20; }
.nf-post-excerpt {
  font-size: 13px;
  color: rgba(26,29,35,0.55);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.nf-btn-ghost-dark {
  display: inline-flex;
  align-items: center;
  padding: 10px 20px;
  border-radius: 10px;
  border: 1px solid rgba(26,29,35,0.14);
  color: #374151;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  transition: border-color 0.18s, color 0.18s;
}
.nf-btn-ghost-dark:hover { border-color: #d92d20; color: #d92d20; text-decoration: none; }

/* ── CONTACT STRIP ───────────────────────────────────────────── */
.nf-contact-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  flex-wrap: wrap;
  padding: 28px 32px;
  border-radius: 16px;
  background: linear-gradient(135deg, #0a1628, #0f1f38);
}
.nf-cs-title {
  font-size: 16px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6px;
}
.nf-cs-sub {
  font-size: 13px;
  color: rgba(255,255,255,0.5);
}
</style>
