---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactCard from "@/components/ContactCard.astro";
import JsonLd from "@/components/JsonLd.astro";
import { categoryMeta } from "@/data/categoryMeta";
import { site } from "@/config/site";
import {
  buildFaqDiscoveryHints,
  buildFaqFilterRows,
  getUnifiedFaqItems,
} from "@/utils/faqAggregate";
import {
  getAllPublishedBaike,
  getAllPublishedPosts,
  getAllPublishedProjects,
  getAllPublishedSchools,
  getAllPublishedServices,
} from "@/utils/content";
import { nocLibrary } from "@/data/nocLibrary";
import { withSiteTitle } from "@/utils/seo";

type DiscoveryContent = {
  href: string;
  title: string;
  kind: string;
  category: string;
  description: string;
  tags: string[];
  searchBlob: string;
};

const unified = await getUnifiedFaqItems();
const [posts, services, projects, baike, schools] = await Promise.all([
  getAllPublishedPosts(),
  getAllPublishedServices(),
  getAllPublishedProjects(),
  getAllPublishedBaike(),
  getAllPublishedSchools(),
]);

const contentItems: DiscoveryContent[] = [
  ...posts.map((p) => ({
    href: `/blog/${p.slug}/`,
    title: p.data.title,
    kind: "博客",
    category: categoryMeta[p.data.category]?.title ?? p.data.category,
    description: p.data.description ?? p.data.excerpt ?? "",
    tags: p.data.tags ?? [],
    searchBlob: [
      p.data.title,
      p.data.description,
      p.data.excerpt,
      p.data.category,
      ...(p.data.tags ?? []),
    ]
      .filter(Boolean)
      .join(" ")
      .toLowerCase(),
  })),
  ...services.map((p) => ({
    href: `/services/${p.slug}/`,
    title: p.data.title,
    kind: "服务",
    category: "服务",
    description: p.data.description ?? p.data.excerpt ?? "",
    tags: p.data.tags ?? [],
    searchBlob: [
      p.data.title,
      p.data.description,
      p.data.excerpt,
      p.data.category,
      ...(p.data.tags ?? []),
    ]
      .filter(Boolean)
      .join(" ")
      .toLowerCase(),
  })),
  ...projects.map((p) => ({
    href: `/projects/${p.slug}/`,
    title: p.data.title,
    kind: "项目",
    category: "项目",
    description: p.data.description ?? p.data.excerpt ?? "",
    tags: p.data.tags ?? [],
    searchBlob: [
      p.data.title,
      p.data.description,
      p.data.excerpt,
      p.data.category,
      ...(p.data.tags ?? []),
    ]
      .filter(Boolean)
      .join(" ")
      .toLowerCase(),
  })),
  ...baike.map((p) => ({
    href: `/baike/${p.slug}/`,
    title: p.data.title,
    kind: "百科",
    category: "百科",
    description: p.data.description ?? p.data.excerpt ?? "",
    tags: p.data.tags ?? [],
    searchBlob: [
      p.data.title,
      p.data.description,
      p.data.excerpt,
      p.data.category,
      ...(p.data.tags ?? []),
    ]
      .filter(Boolean)
      .join(" ")
      .toLowerCase(),
  })),
  ...schools.map((p) => ({
    href: `/school/${p.slug}/`,
    title: p.data.title,
    kind: "院校",
    category: "院校",
    description: p.data.description ?? p.data.excerpt ?? "",
    tags: p.data.tags ?? [],
    searchBlob: [
      p.data.title,
      p.data.description,
      p.data.excerpt,
      p.data.category,
      ...(p.data.tags ?? []),
    ]
      .filter(Boolean)
      .join(" ")
      .toLowerCase(),
  })),
  ...nocLibrary.map((entry) => ({
    href: `/noc/${entry.code}/`,
    title: `NOC ${entry.code} ${entry.titleZh}`,
    kind: "职业库",
    category: "NOC 职业库",
    description: entry.summary,
    tags: entry.tags,
    searchBlob: [
      `noc ${entry.code}`,
      entry.titleZh,
      entry.titleEn,
      entry.family,
      entry.summary,
      ...(entry.tags ?? []),
    ]
      .filter(Boolean)
      .join(" ")
      .toLowerCase(),
  })),
];

const { tagHints, categoryHints } = buildFaqDiscoveryHints(
  posts,
  categoryMeta,
  [
    ...services,
    ...projects,
    ...baike,
    ...schools,
    ...nocLibrary.map((entry) => ({
      slug: entry.code,
      data: {
        title: `NOC ${entry.code} ${entry.titleZh}`,
        excerpt: entry.summary,
        description: entry.summary,
        tags: entry.tags,
        category: "NOC 职业库",
      },
    })),
  ].map((entry) => ({
    slug: entry.slug,
    data: {
      title: entry.data.title,
      excerpt: entry.data.excerpt,
      description: entry.data.description,
      tags: entry.data.tags ?? [],
      category: entry.data.category,
    },
  })),
);

const filterRows = buildFaqFilterRows(unified);

const staticHubs = [
  { label: "移民项目总览", href: "/projects/" },
  { label: "签证服务", href: "/visa/" },
  { label: "移民打分工具", href: "/tools/" },
  { label: "加拿大NOC职业库", href: "/noc/" },
  { label: "EE 定向 / 找工匹配", href: "/services/ee-pathway-job-match/" },
  { label: "EE 技工类定向", href: "/projects/ee-trades/" },
  { label: "新手必读", href: "/immigration/guide/" },
  { label: "移民资讯聚合", href: "/immigration/" },
  { label: "免费申请学校", href: "/school/" },
];

const clientPayload = {
  rows: filterRows,
  tagHints: tagHints.slice(0, 80),
  categoryHints,
  staticHubs,
  contentItems,
};

const faqSchemaCap = 80;
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: unified.slice(0, faqSchemaCap).map((i) => ({
    "@type": "Question",
    name: i.question,
    acceptedAnswer: { "@type": "Answer", text: i.answer },
  })),
};

const categories = [
  { id: "all", label: "全部问题", icon: "📋" },
  { id: "entry", label: "入境 & 签证", icon: "✈️" },
  { id: "pr", label: "永久居民", icon: "🍁" },
  { id: "work", label: "工签 & 雇主", icon: "💼" },
  { id: "study", label: "留学 & 学签", icon: "🎓" },
  { id: "family", label: "家庭 & 团聚", icon: "👨‍👩‍👧" },
] as const;

const payloadJson = JSON.stringify(clientPayload).replace(/</g, "\\u003c");
---

<BaseLayout
  title={withSiteTitle("常见问题 | 全站 FAQ 搜索 · 移民签证高频解答")}
  description="汇总站内常见问题：精选问答 + 博客/项目/服务/百科/院校中的 FAQ；支持关键词搜索，并联想相关标签与文章栏目，方便继续阅读。"
  canonical="https://cachinavisa.com/faq/"
  fullWidth={true}
>
  <JsonLd data={faqLd} />
  <script type="application/json" id="faq-client-payload" set:html={payloadJson} />

  <!-- ── Hero ──────────────────────────────────────────────────── -->
  <section class="faq-hero">
    <div class="faqh-bg"></div>
    <div class="container faqh-inner">
      <div class="faqh-kicker">常见问题</div>
      <h1 class="faqh-title">移民签证常见问题解答</h1>
      <p class="faqh-desc">
        这里不仅包含本站精选问答，还<strong>自动聚合</strong>博客文章、移民项目、服务说明、百科与各省院校页中的 FAQ。用下方搜索框输入关键词，即可筛选问题，并看到<strong>相关标签与栏目</strong>，方便你在站内继续深挖。
      </p>
      <div class="faqh-search-wrap">
        <div class="faqh-search">
          <span class="faqh-search-icon">🔍</span>
          <input
            type="search"
            id="faqSearch"
            class="faqh-search-input"
            placeholder="搜索问题或关键词：学签、省提名、LMIA、续签…"
            autocomplete="off"
            enterkeyhint="search"
          />
        </div>
      </div>

      <div class="faqh-discover" id="faqDiscover" aria-live="polite">
        <div class="fdd-head">
          <span class="fdd-label" id="fddLabel">热门标签与常用入口</span>
          <button type="button" class="fdd-clear" id="fddClear" hidden>清除搜索</button>
        </div>
        <div class="fdd-chips" id="fddChips"></div>
        <div class="fdd-sub" id="fddSub" hidden>
          <span class="fdd-sub-label" id="fddSubLabel"></span>
          <div class="fdd-chips fdd-chips--sub" id="fddChipsSub"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Stats strip ───────────────────────────────────────────── -->
  <div class="faq-stats-strip">
    <div class="container">
      <div class="fss-row">
        <div class="fss-item">
          <span class="fss-num">{unified.length}</span>
          <span class="fss-label">条问答（全站聚合）</span>
        </div>
        <div class="fss-sep">·</div>
        <div class="fss-item">
          <span class="fss-num">8年+</span>
          <span class="fss-label">专业经验</span>
        </div>
        <div class="fss-sep">·</div>
        <div class="fss-item">
          <span class="fss-num">2500+</span>
          <span class="fss-label">成功案例</span>
        </div>
        <div class="fss-sep">·</div>
        <div class="fss-item">
          <span class="fss-num">免费</span>
          <span class="fss-label">初步咨询</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Body ──────────────────────────────────────────────────── -->
  <div class="container faq-body">
    <div class="faq-layout">
      <main>
        <div class="faq-cats" id="faqCats" role="tablist" aria-label="问题分类">
          {categories.map((c) => (
            <button
              type="button"
              class={`faq-cat${c.id === "all" ? " active" : ""}`}
              data-cat={c.id}
              role="tab"
              aria-selected={c.id === "all" ? "true" : "false"}
            >
              <span>{c.icon}</span>
              <span>{c.label}</span>
            </button>
          ))}
        </div>

        <p class="faq-disclaimer">{site.disclaimer}</p>
        <p class="faq-aggregate-note">
          条目出处链接指向原文页面；政策与个案以 IRCC 及官方最新说明为准。
        </p>

        <div class="faq-items" id="faqItems">
          {unified.map((item, idx) => (
            <details class="faq-item-lg" data-faq-i={idx} data-cat={item.category}>
              <summary class="faq-ql">
                <div class="faq-ql-left">
                  <span class="faq-num">{String(idx + 1).padStart(2, "0")}</span>
                  <span class="faq-question">{item.question}</span>
                </div>
                <span class="faq-toggle">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path
                      d="M5 7l4 4 4-4"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </summary>
              <div class="faq-answer">
                <p>{item.answer}</p>
                <p class="faq-source-line">
                  <span class="faq-source-prefix">出处 ·</span>
                  <a href={item.sourceHref}>{item.sourceLabel}</a>
                </p>
                {item.sourceHref !== "/faq/" ? (
                  <div class="faq-source-actions">
                    <a class="faq-source-action" href={item.sourceHref}>查看原文 →</a>
                  </div>
                ) : null}
                {item.tags.length > 0 ? (
                  <div class="faq-item-tags" aria-label="相关标签">
                    {item.tags.map((t) => (
                      <a class="faq-tag-pill" href={`/tag/${encodeURIComponent(t)}/`}>
                        #{t}
                      </a>
                    ))}
                  </div>
                ) : null}
              </div>
            </details>
          ))}
        </div>

        <div class="faq-related" id="faqRelated" hidden>
          <div class="faq-related-head">
            <div>
              <div class="faq-related-kicker">相关内容</div>
              <div class="faq-related-title">博客、服务页与项目页</div>
            </div>
            <div class="faq-related-tip">点开继续看完整说明</div>
          </div>
          <div class="faq-related-list" id="faqRelatedList"></div>
        </div>

        <div class="faq-no-results" id="faqNoResults" style="display:none">
          <div class="fnr-icon">🔍</div>
          <div class="fnr-title">当前筛选下没有匹配的问题</div>
          <p class="fnr-desc">
            试试缩短关键词、切换上方分类，或点击热门标签进栏目浏览。仍不确定可<a href="/contact/">联系我们</a>。
          </p>
        </div>

        <div class="faq-cta-card">
          <div class="faq-cta-icon">💬</div>
          <div>
            <div class="faq-cta-title">没找到您的问题？</div>
            <p class="faq-cta-desc">欢迎发来您的具体情况，顾问将免费为您提供一对一专业解答。</p>
          </div>
          <a href="/contact/" class="btn-primary faq-cta-btn">免费咨询</a>
        </div>
      </main>

      <aside class="faq-sidebar">
        <ContactCard />
        <div class="faq-side-links">
          <div class="fsl-title">延伸阅读</div>
          <div class="fsl-list">
            {[
              { href: "/immigration/guide/", icon: "📖", label: "移民新手必读" },
              { href: "/blog/", icon: "📰", label: "最新政策动态" },
              { href: "/services/", icon: "🛠", label: "我们的服务" },
              { href: "/projects/", icon: "🗺", label: "移民项目总览" },
            ].map((l) => (
              <a href={l.href} class="fsl-item">
                <span class="fsl-icon">{l.icon}</span>
                <span>{l.label}</span>
                <span class="fsl-arrow">→</span>
              </a>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </div>

  <script>
    const el = document.getElementById("faq-client-payload");
    const payload = el?.textContent
      ? JSON.parse(el.textContent)
      : { rows: [], tagHints: [], categoryHints: [], staticHubs: [], contentItems: [] };

    const search = document.getElementById("faqSearch");
    const noResult = document.getElementById("faqNoResults");
    const related = document.getElementById("faqRelated");
    const relatedList = document.getElementById("faqRelatedList");
    const catBar = document.getElementById("faqCats");
    const fddChips = document.getElementById("fddChips")!;
    const fddSub = document.getElementById("fddSub")!;
    const fddSubLabel = document.getElementById("fddSubLabel")!;
    const fddChipsSub = document.getElementById("fddChipsSub")!;
    const fddLabel = document.getElementById("fddLabel")!;
    const fddClear = document.getElementById("fddClear") as HTMLButtonElement | null;

    let activeCat = "all";

    function clearEl(node) {
      while (node.firstChild) node.removeChild(node.firstChild);
    }

    function appendChip(container, href, mainText, subText) {
      const a = document.createElement("a");
      a.className = "fdd-chip";
      a.dataset.variant =
        subText === "栏目" ? "category" : subText === "标签" ? "tag" : "hub";
      a.href = href;
      const main = document.createElement("span");
      main.className = "fdd-chip-main";
      main.textContent = mainText;
      a.appendChild(main);
      if (subText) {
        const sub = document.createElement("span");
        sub.className = "fdd-chip-sub";
        sub.textContent = subText;
        a.appendChild(sub);
      }
      container.appendChild(a);
    }

    function renderDiscover(qRaw) {
      const q = qRaw.trim().toLowerCase();
      const hasQ = q.length > 0;

      if (fddClear) fddClear.hidden = !hasQ;

      clearEl(fddChips);
      clearEl(fddChipsSub);

      if (!hasQ) {
        fddLabel.textContent = "热门标签与常用入口";
        const topTags = payload.tagHints.slice(0, 14);
        for (const t of topTags) {
          appendChip(fddChips, t.href, "#" + t.label, String(t.count) + " 篇");
        }
        const topCats = payload.categoryHints.slice(0, 6);
        for (const c of topCats) {
          appendChip(fddChips, c.href, c.title, "栏目");
        }
        for (const h of payload.staticHubs) {
          appendChip(fddChips, h.href, h.label, "");
        }
        fddSub.hidden = true;
        return;
      }

      fddLabel.textContent = "与搜索词相关";
      const tagMatch = payload.tagHints
        .filter(
          (t) =>
            t.searchBlob.includes(q) ||
            String(t.label).toLowerCase().includes(q),
        )
        .slice(0, 16);
      const catMatch = payload.categoryHints
        .filter(
          (c) =>
            c.searchBlob.includes(q) ||
            c.title.includes(qRaw) ||
            c.slug.includes(q),
        )
        .slice(0, 8);

      if (tagMatch.length) {
        for (const t of tagMatch) {
          appendChip(fddChips, t.href, "#" + t.label, "标签");
        }
      } else {
        const empty = document.createElement("span");
        empty.className = "fdd-empty";
        empty.textContent = "暂无匹配标签，可试其他词或浏览下方问题";
        fddChips.appendChild(empty);
      }

      if (catMatch.length) {
        fddSub.hidden = false;
        fddSubLabel.textContent = "相关文章栏目";
        for (const c of catMatch) {
          appendChip(fddChipsSub, c.href, c.title, "栏目");
        }
      } else {
        fddSub.hidden = true;
      }
    }

    function renderRelatedContent(qRaw) {
      if (!related || !relatedList) return;
      const q = qRaw.trim().toLowerCase();
      clearEl(relatedList);

      if (!q) {
        related.hidden = true;
        return;
      }

      const hits = (payload.contentItems || [])
        .filter(
          (item) =>
            item.searchBlob.includes(q) ||
            String(item.title).toLowerCase().includes(q) ||
            String(item.category).toLowerCase().includes(q) ||
            (item.tags || []).some((t) => String(t).toLowerCase().includes(q)),
        )
        .slice(0, 8);

      if (!hits.length) {
        related.hidden = true;
        return;
      }

      for (const item of hits) {
        const a = document.createElement("a");
        a.className = "faq-related-card";
        a.href = item.href;
        a.innerHTML = `
          <div class="faq-related-card-top">
            <span class="faq-related-kind">${item.kind}</span>
            <span class="faq-related-cat">${item.category}</span>
          </div>
          <div class="faq-related-card-title">${item.title}</div>
          <div class="faq-related-card-desc">${item.description || "点击查看完整说明"}</div>
        `;
        relatedList.appendChild(a);
      }
      related.hidden = false;
    }

    function filterFaq() {
      const q = (search && search.value.trim().toLowerCase()) || "";
      let visible = 0;
      for (const row of payload.rows) {
        const elItem = document.querySelector('[data-faq-i="' + row.i + '"]');
        if (!elItem) continue;
        const catOk = activeCat === "all" || row.c === activeCat;
        const searchOk = !q || row.t.includes(q);
        const show = catOk && searchOk;
        elItem.style.display = show ? "" : "none";
        if (show) visible++;
      }
      if (noResult) noResult.style.display = visible === 0 ? "" : "none";
      renderDiscover((search && search.value) || "");
      renderRelatedContent((search && search.value) || "");
    }

    if (search) search.addEventListener("input", filterFaq);
    if (fddClear) {
      fddClear.addEventListener("click", () => {
        if (search) search.value = "";
        filterFaq();
        if (search) search.focus();
      });
    }

    if (catBar) {
      catBar.addEventListener("click", (e) => {
        const t = e.target;
        const btn = t && t.closest ? t.closest("button[data-cat]") : null;
        if (!btn) return;
        activeCat = btn.getAttribute("data-cat") || "all";
        catBar.querySelectorAll(".faq-cat").forEach((b) => {
          b.classList.toggle("active", b === btn);
          b.setAttribute("aria-selected", b === btn ? "true" : "false");
        });
        filterFaq();
      });
    }

    filterFaq();
  </script>
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────── */
  .faq-hero {
    position: relative;
    background: linear-gradient(135deg, #0a1628 0%, #0f2040 60%, #130a28 100%);
    overflow: hidden;
    padding: 72px 0 56px;
  }
  .faqh-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 70% 30%, rgba(217, 45, 32, 0.12), transparent 60%),
      radial-gradient(ellipse at 25% 70%, rgba(26, 86, 196, 0.1), transparent 60%);
  }
  .faqh-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 760px;
    margin: 0 auto;
  }
  .faqh-kicker {
    display: inline-block;
    padding: 5px 14px;
    border-radius: 999px;
    background: rgba(217, 45, 32, 0.2);
    border: 1px solid rgba(217, 45, 32, 0.3);
    color: #f87171;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .faqh-title {
    font-size: clamp(26px, 4vw, 44px);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin: 0 0 16px;
  }
  .faqh-desc {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.8;
    margin: 0 0 24px;
    text-align: left;
  }
  @media (min-width: 640px) {
    .faqh-desc {
      text-align: center;
    }
  }
  .faqh-search-wrap {
    display: flex;
    justify-content: center;
  }
  .faqh-search {
    position: relative;
    width: 100%;
    max-width: 560px;
    display: flex;
    align-items: center;
  }
  .faqh-search-icon {
    position: absolute;
