  },
  {
    id: "trades",
    color: "#b45309",
    emoji: "🔧",
    name: "特定技工职业类",
    enName: "Trade Occupations",
    target: "both",
    detailLink: "/projects/ee-trades/",
    desc: "覆盖电工、管道工、焊工、木工、零售/批发肉贩等 25 个技工职业，多数无需省级执照，是邀请分数最低（390–450）、入行门槛最低的类别。",
    requirement: "过去 3 年内，在指定技工职业累计 ≥ 12 个月全职工作经验（境内或境外均可）",
