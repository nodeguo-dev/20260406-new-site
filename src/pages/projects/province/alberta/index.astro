---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactCard from "@/components/ContactCard.astro";
import RelatedToolsCard from "@/components/RelatedToolsCard.astro";
import ShareBar from "@/components/ShareBar.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import JsonLd from "@/components/JsonLd.astro";
import { site } from "@/config/site";
import { withSiteTitle } from "@/utils/seo";

const breadcrumbs = [
  { name: "首页", href: "/" },
  { name: "移民项目", href: "/projects/" },
  { name: "省提名计划（PNP）", href: "/projects/provincial-nomination/" },
  { name: "阿尔伯塔省（AAIP）", href: "/projects/province/alberta/" },
];

const streams = [
  {
    name: "Alberta Opportunity Stream（AOS）",
    desc: "面向已在阿省合法工作且满足一定技能条件的申请人，无需在EE候选池，直接向AAIP申请省提名，再转入联邦PR申请。",
    conditions: ["持有效加拿大工签", "在阿省工作经验≥3个月", "职业符合NOC要求（0/A/B/C/D视类别）", "语言达CLB 4–7（视NOC级别）", "学历达高中以上"],
  },
  {
    name: "Alberta Express Entry Stream",
    desc: "与IRCC的Express Entry系统联动，AAIP向EE候选池中符合条件的申请人发出省提名邀请（NOI），获提名后CRS+600分。",
    conditions: ["在EE候选池中", "CRS达到AAIP邀请门槛", "具备阿省工作经验或与阿省经济有连结", "部分类别要求工作offer"],
  },
  {
    name: "Rural Renewal Stream",
    desc: "鼓励外国工人在阿省指定的农村及小城镇社区定居，需由当地社区雇主推荐，并签署定居意愿承诺。",
    conditions: ["在指定阿省农村社区有全职工作offer", "满足该社区具体条件", "符合移民和语言基本要求"],
  },
  {
    name: "Farm Stream",
    desc: "专为农业类自雇或联合农场经营者设计，需证明在阿省有土地、资金且有实际农业经营经验和计划。",
    conditions: ["有农业自雇或联合经营意向", "财务能力证明", "至少2年农业经验", "意愿在阿省农村社区定居"],
  },
];

const faqItems = [
  {
    q: "阿尔伯塔省提名有配额上限吗？",
    a: "有。AAIP每年由联邦分配省提名配额，一旦配额耗尽，AAIP会暂停新申请接收或提高门槛。每年配额通常在6000–9000个提名之间，具体视联邦拨配而定。建议有意向的申请人尽早准备，不要等配额满了再行动。"
  },
  {
    q: "AOS 和 EE Alberta Stream 有什么区别？",
    a: "AOS（Alberta Opportunity Stream）是直接向AAIP申请省提名，不需要进入EE候选池；审批后获得省提名证书，再通过联邦基础通道申请PR，处理时间约12–18个月。Alberta Express Entry Stream则要求申请人在EE候选池中，AAIP通过NOI邀请后获+600分CRS，能更快进入联邦PR流程（目标6个月）。"
  },
  {
    q: "在阿省工作多久后可以申请AAIP？",
    a: "AOS要求在阿省有至少3个月的合法工作经验（在申请时），且工作地点在阿尔伯塔省境内。部分流（如EE Stream）不要求境内工作经验，但通常需要与阿省的「连结」，例如曾在阿省学习或工作。"
  },
  {
    q: "阿省省提名需要雇主支持吗？",
    a: "AOS通常要求申请人在阿省有实际工作（无需雇主出具特别支持信，但需证明工作经历）。EE Alberta Stream部分类别要求有阿省雇主的全职工作offer。农场流则需要自雇或合伙经营证明。"
  },
  {
    q: "阿省经济和就业情况如何？",
    a: "阿尔伯塔省是加拿大能源和农业大省，首府卡尔加里（Calgary）是金融和科技中心，第二大城市埃德蒙顿（Edmonton）是政府和医疗中心。省内无省级个人所得税（联邦税照缴），生活成本相对BC省和安省较低。能源行业受油价影响较大，IT、金融、农业、建筑业较为稳定。"
  },
];

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((c, i) => ({
    "@type": "ListItem", position: i + 1, name: c.name,
    item: new URL(c.href, site.url).toString(),
  })),
};
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((i) => ({
    "@type": "Question", name: i.q,
    acceptedAnswer: { "@type": "Answer", text: i.a },
  })),
};
---

<BaseLayout
  title={withSiteTitle("阿尔伯塔省提名计划（AAIP）申请指南 | 类别·条件·流程")}
  description="阿尔伯塔省提名（AAIP）完整指南：Alberta Opportunity Stream、Express Entry Stream、Rural Renewal Stream 等类别详解，条件对比与常见问题解答。"
  canonical="https://cachinavisa.com/projects/province/alberta/"
>
  <JsonLd data={breadcrumbLd} />
  <JsonLd data={faqLd} />
  <Breadcrumbs items={breadcrumbs} />

  <div class="grid" style="margin-top:16px">
    <article class="content-card">
      <div class="page-header">
        <div class="page-kicker">省提名 · Alberta AAIP</div>
        <h1 class="page-h1">阿尔伯塔省提名计划（AAIP）申请指南</h1>
        <p class="page-intro">
          阿尔伯塔省（Alberta）是加拿大经济最活跃的省份之一，也是近年来省提名配额增长最快的省份之一。
          阿省移民计划（AAIP）提供多个类别，覆盖境内工人、EE候选人、农业经营者及农村定居者，
          处理相对灵活，分数门槛历来较其他主流省份略低。
        </p>
      </div>

      <div class="content-sections">

        <div class="section-block">
          <h2>阿尔伯塔省基本情况</h2>
          <div class="info-grid">
            <div class="info-card">
              <div class="info-card-label">主要城市</div>
              <div class="info-card-value">卡尔加里 / 埃德蒙顿</div>
            </div>
            <div class="info-card">
              <div class="info-card-label">主要语言</div>
              <div class="info-card-value">英语</div>
            </div>
            <div class="info-card">
              <div class="info-card-label">主要产业</div>
              <div class="info-card-value">能源、金融、农业、建筑、IT</div>
            </div>
            <div class="info-card">
              <div class="info-card-label">省个人所得税</div>
              <div class="info-card-value">无（全加最低税负）</div>
            </div>
            <div class="info-card">
              <div class="info-card-label">年 AAIP 配额（约）</div>
              <div class="info-card-value">6,000–9,000 个</div>
            </div>
            <div class="info-card">
              <div class="info-card-label">EE 通道门槛（参考）</div>
              <div class="info-card-value">历史上 300–500 分</div>
            </div>
          </div>
        </div>

        <div class="section-block">
          <h2>主要申请类别</h2>
          <div class="streams-list">
            {streams.map((s) => (
              <div class="stream-item">
                <div class="stream-name">{s.name}</div>
                <div class="stream-desc">{s.desc}</div>
                <div class="stream-conditions">
                  {s.conditions.map((c) => (
                    <div class="stream-cond">
                      <span class="sc-dot">✓</span>
                      <span>{c}</span>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="section-block">
          <h2>AOS 申请流程（境内工人路径）</h2>
          <ol class="step-list">
            <li><span class="step-text"><strong>确认工作经验与职位NOC</strong><span class="step-sub">核查在阿省的工作时间（≥3个月）和职业类别是否符合AAIP AOS要求</span></span></li>
            <li><span class="step-text"><strong>准备语言成绩</strong><span class="step-sub">根据NOC类别要求准备雅思或CELPIP成绩（CLB 4–7）</span></span></li>
            <li><span class="step-text"><strong>向 AAIP 提交省提名申请</strong><span class="step-sub">在 AAIP 官网系统上传所有材料，AAIP 审核（约4–6个月）</span></span></li>
            <li><span class="step-text"><strong>获得省提名证书</strong><span class="step-sub">拿到省提名后，通过基础通道向 IRCC 提交联邦 PR 申请</span></span></li>
            <li><span class="step-text"><strong>等待联邦审批</strong><span class="step-sub">基础通道 PR 处理时间约 12–18 个月，期间可继续在加拿大工作</span></span></li>
          </ol>
        </div>

        <div class="section-block">
          <h2>常见问题（FAQ）</h2>
          {faqItems.map((item) => (
            <details class="faq-item">
              <summary class="faq-q">{item.q}</summary>
              <p class="faq-a">{item.a}</p>
            </details>
          ))}
        </div>

      </div>
      <div class="page-share">
        <ShareBar url="https://cachinavisa.com/projects/province/alberta/" title={"阿尔伯塔省提名计划（AAIP）申请指南 | 类别·条件·流程"} />
      </div>


      <div class="cta-inline">
        <div class="cta-text">想免费评估 AAIP 哪个类别适合你？</div>
        <a class="cta-btn" href="/contact/">免费咨询 →</a>
      </div>
    </article>

    <aside class="sidebar-stack">
      <ContactCard />
      <RelatedToolsCard
        title="相关打分工具"
        subtitle="阿省项目常用 AAIP EOI，EE 路线则同步看 CRS。"
        items={[
          { href: "/tools/aaip-calculator/", label: "AAIP Worker EOI", desc: "阿省 Worker 类分值直接预估。" },
          { href: "/tools/crs-calculator/", label: "联邦 CRS 计算器", desc: "如果你走 EE 相关通道，先算 CRS。" },
          { href: "/tools/", label: "打分工具总览", desc: "省提名与联邦工具一起对照更稳。" },
        ]}
        footerHref="/tools/aaip-calculator/"
        footerLabel="直接计算 AAIP 分数"
      />
      <div class="sidebar-nav-card">
        <div class="snc-title">各省提名</div>
        <div class="snc-links">
          <a class="snc-link" href="/projects/province/ontario/">安大略省（OINP）</a>
          <a class="snc-link" href="/projects/province/british-columbia/">不列颠哥伦比亚省</a>
          <a class="snc-link" href="/projects/province/quebec/">魁北克省</a>
          <a class="snc-link active" href="/projects/province/alberta/">阿尔伯塔省（AAIP）</a>
        </div>
      </div>
      <div class="sidebar-nav-card">
        <div class="snc-title">相关移民路径</div>
        <div class="snc-links">
          <a class="snc-link" href="/projects/provincial-nomination/">省提名项目总览</a>
          <a class="snc-link" href="/projects/cec/">CEC 转永居</a>
          <a class="snc-link" href="/visa/work-permit/">工签申请指南</a>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
.grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
@media (min-width: 920px) { .grid { grid-template-columns: 1fr 300px; align-items: start; } }
.content-card { background: #fff; border: 1px solid rgba(26,29,35,0.09); border-radius: 16px; overflow: hidden; }
.page-header { padding: 28px 28px 24px; border-bottom: 1px solid rgba(26,29,35,0.08); background: linear-gradient(135deg, #fafbff, #fff); }
.page-kicker { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #d92d20; margin-bottom: 8px; }
.page-h1 { font-size: clamp(20px, 3.5vw, 28px); font-weight: 800; color: #1a1d23; margin: 0 0 12px; letter-spacing: -0.02em; }
.page-intro { font-size: 15px; color: rgba(26,29,35,0.62); line-height: 1.7; margin: 0; }
.content-sections { padding: 24px 28px; display: grid; gap: 32px; }
.section-block h2 { font-size: 18px; font-weight: 750; color: #1a1d23; margin: 0 0 14px; padding-bottom: 8px; border-bottom: 2px solid rgba(217,45,32,0.12); }

.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
@media (min-width: 560px) { .info-grid { grid-template-columns: repeat(3, 1fr); } }
.info-card { padding: 14px 16px; background: rgba(26,29,35,0.03); border-radius: 12px; border: 1px solid rgba(26,29,35,0.07); }
.info-card-label { font-size: 12px; color: rgba(26,29,35,0.45); margin-bottom: 4px; }
.info-card-value { font-size: 13.5px; font-weight: 600; color: #1a1d23; }

.streams-list { display: grid; gap: 14px; }
.stream-item { padding: 18px 20px; background: rgba(26,29,35,0.02); border-radius: 14px; border: 1px solid rgba(26,29,35,0.08); }
.stream-name { font-size: 15px; font-weight: 700; color: #1a1d23; margin-bottom: 7px; }
.stream-desc { font-size: 13.5px; color: rgba(26,29,35,0.6); line-height: 1.6; margin-bottom: 12px; }
.stream-conditions { display: flex; flex-direction: column; gap: 5px; }
.stream-cond { display: flex; gap: 8px; align-items: flex-start; font-size: 13px; color: rgba(26,29,35,0.65); }
.sc-dot { color: #059669; font-weight: 700; flex-shrink: 0; }

.step-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; counter-reset: steps; }
.step-list li { display: flex; gap: 14px; align-items: flex-start; counter-increment: steps; }
.step-list li::before { content: counter(steps); display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; min-width: 28px; border-radius: 50%; background: #d92d20; color: #fff; font-weight: 700; font-size: 13px; margin-top: 2px; }
.step-text { display: flex; flex-direction: column; gap: 5px; }
.step-text strong { font-size: 14px; color: #1a1d23; }
.step-sub { font-size: 13px; color: rgba(26,29,35,0.6); line-height: 1.65; }

.faq-item { border: 1px solid rgba(26,29,35,0.08); border-radius: 12px; overflow: hidden; margin-bottom: 8px; }
.faq-q { padding: 14px 18px; font-size: 14px; font-weight: 600; color: #1a1d23; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 8px; }
.faq-q::after { content: '+'; font-size: 18px; color: #d92d20; font-weight: 400; flex-shrink: 0; }
details[open] .faq-q::after { content: '−'; }
.faq-a { padding: 12px 18px 14px; font-size: 13.5px; color: rgba(26,29,35,0.65); line-height: 1.75; margin: 0; border-top: 1px solid rgba(26,29,35,0.06); }

.cta-inline { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 28px; background: linear-gradient(135deg, rgba(217,45,32,0.05), rgba(217,45,32,0.02)); border-top: 1px solid rgba(217,45,32,0.1); flex-wrap: wrap; }
.cta-text { font-size: 15px; font-weight: 600; color: #1a1d23; }
.cta-btn { padding: 10px 22px; background: #d92d20; color: #fff; border-radius: 10px; font-weight: 700; font-size: 14px; text-decoration: none; white-space: nowrap; }
.cta-btn:hover { background: #b52418; text-decoration: none; }

.sidebar-stack { display: grid; gap: 16px; position: sticky; top: 80px; }
.sidebar-nav-card { background: #fff; border: 1px solid rgba(26,29,35,0.09); border-radius: 14px; padding: 18px 20px; }
.snc-title { font-size: 14px; font-weight: 700; color: #1a1d23; margin-bottom: 12px; padding-bottom: 10px; border-bottom: 1px solid rgba(26,29,35,0.08); }
.snc-links { display: flex; flex-direction: column; gap: 2px; }
.snc-link { display: block; padding: 8px 10px; font-size: 13.5px; color: #374151; text-decoration: none; border-radius: 8px; }
.snc-link:hover { background: rgba(217,45,32,0.06); color: #d92d20; text-decoration: none; }
.snc-link.active { background: rgba(217,45,32,0.07); color: #d92d20; font-weight: 600; }
</style>
