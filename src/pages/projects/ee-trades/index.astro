---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactCard from "@/components/ContactCard.astro";
import RelatedToolsCard from "@/components/RelatedToolsCard.astro";
import ShareBar from "@/components/ShareBar.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import JsonLd from "@/components/JsonLd.astro";
import { site } from "@/config/site";
import { withSiteTitle } from "@/utils/seo";

const breadcrumbs = [
  { name: "首页", href: "/" },
  { name: "移民项目", href: "/projects/" },
  { name: "EE 定向邀请（CBS）", href: "/projects/ee-category/" },
  { name: "技工类定向移民", href: "/projects/ee-trades/" },
];

/* ─── 职业列表（2026年有效名单）─── */
const tradeJobs = [
  { noc: "70010", name: "建筑项目经理", en: "Construction managers", license: false, note: "一般需有多年技工管理经验" },
  { noc: "70011", name: "住宅建筑与翻新经理", en: "Home building and renovation managers", license: false, note: "装修公司管理职位" },
  { noc: "72100", name: "机械加工技工与检验员", en: "Machinists and tooling inspectors", license: false, note: "工厂机械加工职位" },
  { noc: "72102", name: "钣金工", en: "Sheet metal workers", license: false, note: "常见于HVAC、建筑行业" },
  { noc: "72106", name: "焊工及相关机械操作员", en: "Welders", license: false, note: "部分雇主要求CWB认证，但非法定" },
  { noc: "72200", name: "电工（非工业/电力系统）", en: "Electricians (residential/commercial)", license: true, note: "各省要求持省级电工执照" },
  { noc: "72201", name: "工业电工", en: "Industrial electricians", license: true, note: "工厂/工业场所，需执照" },
  { noc: "72300", name: "管道工", en: "Plumbers", license: true, note: "各省执照要求不同，安省等需持牌" },
  { noc: "72302", name: "燃气安装技工", en: "Gas fitters", license: true, note: "操作天然气设备须持G2/G1执照" },
  { noc: "72310", name: "木工", en: "Carpenters", license: false, note: "建筑行业最常见职位之一" },
  { noc: "72311", name: "橱柜制造工", en: "Cabinetmakers", license: false, note: "家具/室内装修行业" },
  { noc: "72320", name: "砌砖工", en: "Bricklayers", license: false, note: "建筑施工类" },
  { noc: "72400", name: "建筑机械师及工业机械师", en: "Construction millwrights", license: false, note: "机器设备安装维修" },
  { noc: "72401", name: "重型机械技工", en: "Heavy-duty equipment mechanics", license: false, note: "工程机械维修，矿业/建筑业需求大" },
  { noc: "72402", name: "暖通空调机械师（HVAC）", en: "HVAC mechanics", license: false, note: "部分省份要求制冷剂操作证" },
  { noc: "72422", name: "电气机械技工", en: "Electrical mechanics", license: false, note: "工业电气维护岗位" },
  { noc: "72501", name: "水井钻探工", en: "Water well drillers", license: true, note: "部分省份要求持牌" },
  { noc: "72999", name: "其他技术工种", en: "Other technical trades", license: false, note: "含多种专业技工" },
  { noc: "73100", name: "混凝土修整工", en: "Concrete finishers", license: false, note: "建筑施工类" },
  { noc: "73110", name: "屋顶工和瓦工", en: "Roofers and shinglers", license: false, note: "找工作相对容易，旺季需求大" },
  { noc: "73112", name: "油漆工（室外/商业）", en: "Painters and decorators", license: false, note: "装修行业基础职位" },
  { noc: "73113", name: "地板铺设工", en: "Floor covering installers", license: false, note: "装修行业常见职位" },
  { noc: "82021", name: "石油钻探承包商及主管", en: "Oil and gas drilling contractors", license: false, note: "阿省、BC省能源行业" },
  { noc: "22303", name: "建筑估算师", en: "Construction estimators", license: false, note: "文职+技术结合岗位" },
  { noc: "63201", name: "零售/批发肉贩", en: "Butchers - retail and wholesale", license: false, note: "2026年新增！官方技工 CBS 名单新增职业" },
];

const noLicenseJobs = tradeJobs.filter(j => !j.license);

/* ─── 最新抽签数据 ─── */
const latestRound = {
  date: "2026年（近期）",
  score: 477,
  type: "技工类定向（Trade Occupations）",
  note: "比同期普通邀请分低约 40–60 分，说明技工类定向通道对中低分候选人极为有利。"
};

/* ─── 零经验快速入行岗位（短期培训即可上岗）─── */
const quickStartJobs = [
  {
    noc: "63201",
    name: "零售/批发肉贩",
    en: "Butchers - retail and wholesale",
    trainTime: "短则 1–3 个月在岗学习",
    salary: "$18–$28/小时",
    demand: "高",
    howToStart: "可从肉铺助手、超市肉类部门助手、批发肉类加工或包装岗位入行，边做边学习分割、修整、包装和食品安全流程；华人超市、连锁超市和肉类批发企业都可能是起点。",
    license: false,
    highlight: "IRCC 2026 官方技工 CBS 名单新增职业，适合食品零售、超市和批发加工方向求职者",
  },
  {
    noc: "73110",
    name: "屋顶工 / 瓦工",
    en: "Roofers and shinglers",
    trainTime: "1–4 周在岗培训",
    salary: "$22–$35/小时",
    demand: "高",
    demandNote: "旺季4–10月需求翻倍",
    howToStart: "春夏季是旺季，小型屋顶公司大量招聘体力工人，无需学历，雇主直接培训。搜索 Indeed roofer helper 或联系当地小型建筑公司。",
    license: false,
    highlight: "体力劳动，入行门槛极低，旺季时薪可达 $30+，是快速积累经验的务实选择",
  },
  {
    noc: "73112",
    name: "油漆工（商业/住宅）",
    en: "Painters and decorators",
    trainTime: "1–4 周在岗培训",
    salary: "$20–$32/小时",
    demand: "高",
    howToStart: "学徒或助手（Painter's Helper）直接进入，跟着有经验的油漆工学习。小型装修公司、物业管理公司大量招聘，LinkedIn/Kijiji/Facebook 工作群均可找到 lead。",
    license: false,
    highlight: "室内外装修需求旺盛，华人承包商多，找工作有语言优势",
  },
  {
    noc: "73113",
    name: "地板铺设工",
    en: "Floor covering installers",
    trainTime: "2–6 周在岗学习",
    salary: "$22–$38/小时",
    demand: "高",
    howToStart: "地板材料商（如 Floor Depot、地板店）或小型装修公司招聘助手，学习铺设硬木地板、瓷砖、LVP 等，技能可快速转化为高薪独立承包商。",
    license: false,
    highlight: "技术成熟后可做独立承包商，时薪潜力高",
  },
  {
    noc: "72310",
    name: "木工（建筑施工类）",
    en: "Carpenters",
    trainTime: "2–8 周助手经验后可独立",
    salary: "$24–$42/小时",
    demand: "极高（住宅/商业建筑缺口大）",
    howToStart: "以 Carpenter's Helper / Labour 职位入行，协助框架、干墙（Drywall）等工序。加拿大建筑工地大量缺人，特别是多伦多、卡尔加里、埃德蒙顿等在建项目多的城市。",
    license: false,
    highlight: "是所有技工职位中雇主最多、最容易入行的路线之一",
  },
  {
    noc: "72106",
    name: "焊工",
    en: "Welders",
    trainTime: "College 8个月证书课程 / 或 3–6 个月基础培训",
    salary: "$25–$45/小时（CWB认证后更高）",
    demand: "高",
    howToStart: "College 焊接技术证书（如 NAIT、George Brown、Mohawk 均有）是最快的系统入门方式，8个月毕业即可就业。也可直接应聘焊工助手，边干边学。",
    license: false,
    highlight: "技能可量化（CWB 焊接资质），越有认证收入越高，阿省/BC省石油行业需求巨大",
  },
  {
    noc: "72402",
    name: "暖通空调技师（HVAC）",
    en: "HVAC mechanics",
    trainTime: "College 1–2 年课程",
    salary: "$28–$48/小时",
    demand: "高",
    howToStart: "College HVAC 技术课程（1–2年）是标准路径，毕业后直接进入安装/维修公司。部分雇主提供学徒计划，边工作边考制冷剂操作证。",
    license: false,
    highlight: "冬夏季均为旺季，年薪 6 万+ 普遍，是技工类中薪资/稳定性最佳的职位之一",
  },
];

const pathSteps = [
  {
    num: "1",
    title: "确定目标职业（NOC）",
    desc: "从上方职业列表中选出 1–2 个最符合你背景或最容易就业的 NOC 类别。重点考量：本地就业市场需求、是否需要执照（电工/管道工有执照要求）、你的学习成本。",
    tips: ["焊工、木工、HVAC、油漆工、屋顶工是门槛较低且容易找工作的职位", "零售/批发肉贩（NOC 63201）是 2026 年官方新增技工 CBS 职业，适合走超市、肉铺或批发加工路线"],
  },
  {
    num: "2",
    title: "获取技能与资质",
    desc: "大多数技工类职位不需要省级执照，只需要雇主认可你具备该职业能力。以下方式均可帮你快速进入该行业：",
    tips: [
      "College 职业技术项目（通常 1–2 年），如 George Brown、Fanshawe、NAIT、BCIT 等均有技工专项",
      "学徒计划（Apprenticeship）：边工作边学，雇主担保，是技工行业主流晋升路径",
      "海外技工经验：如有境外相关工作经验，可直接进入同类岗位并开始积累加拿大经验",
    ],
  },
  {
    num: "3",
    title: "在加拿大找到对口工作",
    desc: "持有学签（在校期间兼职/实习）或毕业后持 PGWP 工签都可以开始积累经验。技工行业在加拿大供不应求，尤其是 BC 省、安省、阿省的建筑和能源行业。",
    tips: [
      "招聘渠道：Indeed、Workopolis、各省建筑工会（如 UA Local 联合管道工会）、雇主直聘",
      "很多小型建筑/装修公司不要求执照，只要能胜任工作即可上岗",
      "PGWP 工签最长 3 年，时间充足积累 12 个月经验",
    ],
  },
  {
    num: "4",
    title: "积累 12 个月工作经验，建立 EE Profile",
    desc: "在过去 3 年内累计完成 ≥ 12 个月全职技工类工作（可不连续）后，登录 IRCC 官网创建 Express Entry 档案（Profile），如实填写工作经验 NOC 类别。",
    tips: [
      "工资单、T4 税单、雇主证明信是最重要的经验证明材料",
      "兼职可以算但需折算为全职等效：每周 30 小时 = 全职",
      "Profile 有效期 1 年，期间可随时更新信息",
    ],
  },
  {
    num: "5",
    title: "等待 CBS 技工定向邀请",
    desc: "进入 EE 候选池后，IRCC 会定期举行技工类（Trade Occupations）定向抽签。历史数据显示技工类定向邀请是所有 CBS 类别中分数最低、最频繁的，无需等到分数线极高的普通邀请。",
    tips: [
      "历史技工类定向邀请分数：390–450 分（普通邀请通常 490–540 分）",
      "同时可通过提高语言成绩（CLB 9+）、获取 PNP 省提名等方式进一步提高 CRS 分数",
      "无需主动选择进入 CBS——只要 EE Profile 中填写了技工 NOC，系统自动识别",
    ],
  },
];

const faqs = [
  {
    q: "技工类定向邀请是多久一次？每次邀请多少人？",
    a: "IRCC 没有固定时间表，但技工类（Trades）在 2024–2026 年间属于最频繁举行的 CBS 类别之一，通常每年 3–6 次，每次邀请 500–2000 人不等。建议进入候选池后设置 IRCC 邮件通知，每次有新一轮邀请都会收到通知。"
  },
  {
    q: "我没有任何技工背景，可以从零学习进入这条路线吗？",
    a: "完全可以。加拿大很多 College 提供 1–2 年的技工技术证书课程（Certificate/Diploma），毕业后可申请 PGWP 工签，从事对口技工职位。从零开始的学习成本最低的职业包括：油漆工（部分公司可直接入职学习）、地板铺设工、木工助手（后晋升为木工）、HVAC 学徒等。"
  },
  {
    q: "电工和管道工需要省级执照，我该不该选这两个职位？",
    a: "需要执照的职位（如电工/管道工）在就业和移民上都有更强的竞争力——持牌电工/管道工工资更高、雇主愿意担保、移民路径也更明确。但取得执照需要完成学徒期（通常 4–5 年），适合长期规划的申请人。如果希望快速积累 12 个月经验拿定向 ITA，建议优先选择不需要执照的职业（如焊工、HVAC、木工等），速度更快。"
  },
  {
    q: "2026 年新增进入技工 CBS 名单的到底是不是厨师？",
    a: "不是。根据 IRCC 官方 category-based selection 页面，截至 2026 年 4 月，新增进入技工类 Trade occupations 名单的是 Butchers - retail and wholesale，NOC 63201，TEER 3；官网页面并没有把 Cooks（厨师，NOC 63200）列入当前技工类别。准备职业路径和申请材料时，一定要以官方职业清单为准。"
  },
  {
    q: "技工类工作工资如何？能满足移民申请的经济要求吗？",
    a: "加拿大技工类职位工资普遍较高，以下是参考范围（因省份和经验有差异）：木工 $25–38/小时、焊工 $28–42/小时、电工 $35–50/小时、HVAC 技师 $30–45/小时、零售/批发肉贩约 $18–28/小时。PR 申请本身没有固定最低工资要求，关键是合法、真实、可证明的全职工作经验。"
  },
  {
    q: "我同时符合技工类 CBS 和医护类 CBS，应该选哪个？",
    a: "不需要选，两个条件都填写在 EE Profile 里，IRCC 会在任一符合条件的定向轮次中邀请你。如果两类都有工作经验，意味着你进入 ITA 的通道更多，是好事。建议专注于最能稳定就业、薪资最好的那个职业。"
  },
];

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((c, i) => ({
    "@type": "ListItem", position: i + 1, name: c.name,
    item: new URL(c.href, site.url).toString(),
  })),
};
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((i) => ({
    "@type": "Question", name: i.q,
    acceptedAnswer: { "@type": "Answer", text: i.a },
  })),
};
---

<BaseLayout
  title={withSiteTitle("EE 技工类定向移民完整指南 | 25个职业 · 无需执照路径 · 肉贩新增")}
  description="2026年 Express Entry 技工类定向邀请（Trade Occupations CBS）详解：25个覆盖职业、哪些无需执照、如何在加拿大找到技工工作、积累1年经验进入EE候选池。注意：官方新增职业是 Butchers - retail and wholesale（NOC 63201），不是 Cooks。"
  canonical="https://cachinavisa.com/projects/ee-trades/"
>
  <JsonLd data={breadcrumbLd} />
  <JsonLd data={faqLd} />
  <Breadcrumbs items={breadcrumbs} />

  <div class="page-layout" style="margin-top:16px">
    <main>

      <!-- 🔥 Latest round alert -->
      <div class="round-alert">
        <div class="ra-left">
          <span class="ra-badge">🔥 最新动态</span>
          <div class="ra-title">技工类定向抽签：截止分 <strong>{latestRound.score} 分</strong></div>
          <div class="ra-desc">
            IRCC 近期完成一轮技工类（Trade Occupations）CBS 定向邀请，最低邀请分为 <strong>{latestRound.score} 分</strong>，
            比同期普通邀请低约 40–60 分。这说明目前处于候选池、CRS 分数在 460–490 区间的技工背景申请人
            已具备极大概率在下一轮被邀请。
          </div>
          <div class="ra-insight">
            💡 <strong>对还没工作经验的人的启发：</strong>找一份技工类岗位，哪怕是门槛最低的（零售/批发肉贩、油漆工、屋顶工、木工助手），
            累计 12 个月经验进入 EE 候选池，就可以等待下一次 477 分左右的定向邀请——
            这个分数对于有加拿大学历或一定工作经验的人是完全可以达到的。
          </div>
        </div>
        <div class="ra-score">
          <div class="ras-num">{latestRound.score}</div>
          <div class="ras-label">最新邀请截止分</div>
          <a class="ras-link" href="https://www.canada.ca/en/immigration-refugees-citizenship/services/immigrate-canada/express-entry/rounds-invitations.html" target="_blank" rel="noopener">查看 IRCC 官方记录 →</a>
        </div>
      </div>

      <!-- Hero -->
      <div class="page-hero">
        <div class="hero-kicker">EE 定向邀请 · 技工类</div>
        <h1 class="hero-title">技工类定向移民<br /><span class="hero-title-en">Trade Occupations CBS</span></h1>
        <p class="hero-desc">
          技工类（Trade Occupations）是 CBS 定向邀请中<strong>分数最低、邀请频率最高</strong>的类别之一。
          2026 年共覆盖 25 个职业，其中大多数<strong>不需要省级执照</strong>，只要找到对口工作并积累 12 个月经验，
          就可以进入 EE 候选池等待定向 ITA。这是技术门槛低、移民路径清晰的务实选项。
        </p>
        <div class="hero-tags">
          <span class="htag green">历史邀请分：390–450分</span>
          <span class="htag orange">25个覆盖职业</span>
          <span class="htag blue">多数无需执照</span>
          <span class="htag red">63201 官方新增</span>
        </div>
      </div>

      <!-- Why Trades -->
      <div class="content-card">
        <h2 class="cc-title">为什么技工类是"万能油"移民路径？</h2>
        <div class="why-grid">
          <div class="why-item">
            <div class="wi-icon">🔑</div>
            <div class="wi-title">大多数无需执照</div>
            <div class="wi-desc">25 个覆盖职业中，焊工、木工、HVAC、屋顶工、零售/批发肉贩等大多数职位只需要雇主认可你的能力，无需政府颁发的省级执照。相比医护类的注册认证流程，入行门槛低很多。</div>
          </div>
          <div class="why-item">
            <div class="wi-icon">📉</div>
            <div class="wi-title">邀请分数最低</div>
            <div class="wi-desc">历史数据显示，技工类定向邀请的截止分数在 390–450 分之间，是所有 CBS 类别中最低的。这意味着即使你的 CRS 分数不高，只要工作经验达标就有机会被邀请。</div>
          </div>
          <div class="why-item">
            <div class="wi-icon">🏗️</div>
            <div class="wi-title">市场需求极大</div>
