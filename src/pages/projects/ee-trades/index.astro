<script>
  const filterBtns = document.querySelectorAll('.jf-btn');
  const jobRows = document.querySelectorAll('.jt-row:not(.jt-header)');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = (btn as HTMLElement).dataset.filter;
      jobRows.forEach(row => {
        const el = row as HTMLElement;
        if (filter === 'all') { el.style.display = ''; }
        else if (filter === 'no-license') { el.style.display = el.dataset.license === 'no' ? '' : 'none'; }
        else if (filter === 'license') { el.style.display = el.dataset.license === 'yes' ? '' : 'none'; }
      });
    });
  });
</script>

