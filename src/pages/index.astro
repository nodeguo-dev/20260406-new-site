<script is:inline>
  (function () {
    function easeOutCubic(t) {
      return 1 - Math.pow(1 - t, 3);
    }
    function runCount(el, duration) {
      var end = parseInt(el.getAttribute("data-count-end") || "0", 10);
      var suffix = el.getAttribute("data-suffix") || "";
      var start = performance.now();
      function frame(now) {
        var t = Math.min(1, (now - start) / duration);
        var eased = easeOutCubic(t);
        var val = Math.round(eased * end);
        el.textContent = val + suffix;
        if (t < 1) requestAnimationFrame(frame);
        else el.textContent = end + suffix;
      }
      requestAnimationFrame(frame);
    }
    var root = document.querySelector("[data-hero-stats]");
    if (!root) return;
    var els = root.querySelectorAll(".hsc-value-count[data-count-end]");
    if (!els.length) return;
    var started = false;
    var durations = [2200, 1600, 1200];
    function start() {
      if (started) return;
      started = true;
      els.forEach(function (el, i) {
        runCount(el, durations[i] || 1800);
      });
    }
    if ("IntersectionObserver" in window) {
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              start();
              io.disconnect();
            }
          });
        },
        { threshold: 0.25 }
      );
      io.observe(root);
    } else {
      start();
    }
  })();
</script>
